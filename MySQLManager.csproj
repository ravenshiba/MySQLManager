<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>MySQLManager</AssemblyName>
    <RootNamespace>MySQLManager</RootNamespace>
    <ApplicationIcon>Resources\Icons\app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- MySQL 官方驅動 (非同步支援佳) -->
    <PackageReference Include="MySqlConnector" Version="2.3.7" />
    <!-- MVVM 框架 -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    <!-- SQL 語法高亮編輯器 -->
    <PackageReference Include="AvalonEdit" Version="6.3.0.90" />
    <!-- JSON 設定儲存 -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="SSH.NET" Version="2024.2.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- App icon -->
    <Resource Include="Resources\Icons\app.ico"/>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources/Highlighting/MySQL.xshd"/>
  </ItemGroup>

</Project>
