<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#C62828</Color>
    <Color x:Key="AccentDimColor">#B71C1C</Color>
    <Color x:Key="Accent2Color">#D81B60</Color>
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="Accent2Brush"   Color="{StaticResource Accent2Color}"/>
</ResourceDictionary>