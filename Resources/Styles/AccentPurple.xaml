<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#7B1FA2</Color>
    <Color x:Key="AccentDimColor">#6A1B9A</Color>
    <Color x:Key="Accent2Color">#9C27B0</Color>
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="Accent2Brush"   Color="{StaticResource Accent2Color}"/>
</ResourceDictionary>