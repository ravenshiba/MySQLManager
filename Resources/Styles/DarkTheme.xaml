<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         深色主題色彩系統
    ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="BgDeepColor">#1A1B1E</Color>
    <Color x:Key="BgPanelColor">#25262B</Color>
    <Color x:Key="BgSurfaceColor">#2C2E33</Color>
    <Color x:Key="BgCardColor">#1E1F23</Color>
    <Color x:Key="BgHoverColor">#2A3550</Color>
    <Color x:Key="AccentColor">#4DA3FF</Color>
    <Color x:Key="AccentDimColor">#3B8FE8</Color>
    <Color x:Key="Accent2Color">#A57FFF</Color>
    <Color x:Key="TextPrimaryColor">#E8EAED</Color>
    <Color x:Key="TextSecondaryColor">#9AA0A6</Color>
    <Color x:Key="TextDimColor">#5F6368</Color>
    <Color x:Key="BorderColor">#3C3F45</Color>
    <Color x:Key="BorderBrightColor">#4A5568</Color>
    <Color x:Key="SuccessColor">#34A853</Color>
    <Color x:Key="WarningColor">#F9AB00</Color>
    <Color x:Key="ErrorColor">#F28B82</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush"       Color="{StaticResource BgPanelColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush"      Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="{StaticResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="HoverBrush"          Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="DeepBrush"           Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="Accent2Brush"        Color="{StaticResource Accent2Color}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDimBrush"        Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="BorderBrush"         Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderBrightBrush"   Color="{StaticResource BorderBrightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"        Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush"          Color="{StaticResource ErrorColor}"/>

    <!-- Accent Gradient -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3B8FE8" Offset="0"/>
        <GradientStop Color="#2979CC" Offset="1"/>
    </LinearGradientBrush>

    <!-- Status Bar Gradient -->
    <LinearGradientBrush x:Key="StatusBarGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A1B1E" Offset="0"/>
        <GradientStop Color="#25262B" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
