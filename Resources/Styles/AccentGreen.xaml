<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#2E7D32</Color>
    <Color x:Key="AccentDimColor">#1B5E20</Color>
    <Color x:Key="Accent2Color">#00897B</Color>
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="Accent2Brush"   Color="{StaticResource Accent2Color}"/>
</ResourceDictionary>