<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#E65100</Color>
    <Color x:Key="AccentDimColor">#BF360C</Color>
    <Color x:Key="Accent2Color">#FF6D00</Color>
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="Accent2Brush"   Color="{StaticResource Accent2Color}"/>
</ResourceDictionary>