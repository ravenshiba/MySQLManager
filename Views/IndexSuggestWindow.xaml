<Window x:Class="MySQLManager.Views.IndexSuggestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.AI4d5c14}" Height="560" Width="860"
        MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="{DynamicResource S.SQLa9e370}" Click="Analyze_Click"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.SQL3664bd}" Click="CopySql_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.INDEX3c7ae5}" Click="ExecuteIndex_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Foreground="#1B5E20"/>
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Suggestions grid -->
        <DataGrid Grid.Row="1" x:Name="SuggestionGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F9FA"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                  SelectionChanged="SuggestionGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource S.kb91da3}" Binding="{Binding ImpactIcon}" Width="46"/>
                <DataGridTextColumn Header="{DynamicResource S.k935edb}" Binding="{Binding Impact}"     Width="60"/>
                <DataGridTextColumn Header="{DynamicResource S.k7b5e7c}" Binding="{Binding Table}"    Width="120"/>
                <DataGridTextColumn Header="{DynamicResource S.k8f38f8}"   Binding="{Binding Columns}"  Width="160"/>
                <DataGridTextColumn Header="{DynamicResource S.k41dfb0}"   Binding="{Binding Reason}"   Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- SQL Preview -->
        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{DynamicResource S.SQL181cee}"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           Padding="10,6,10,2"/>
                <TextBox Grid.Row="1" x:Name="SqlPreview"
                         IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         Background="{StaticResource PrimaryBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderThickness="0" Padding="10,4"/>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="4" x:Name="FooterLabel"
                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,6,0,0"
                   Text="{DynamicResource S.EXPLAINc4abc3}"/>
    </Grid>
</Window>
