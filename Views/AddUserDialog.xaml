<Window x:Class="MySQLManager.Views.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.k0bf5f6}" Height="280" Width="400"
        MinWidth="360" MinHeight="260"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
    </Window.Resources>
    <StackPanel Margin="24">
        <TextBlock Text="{DynamicResource S.MySQLdc538d}" FontSize="14" FontWeight="Bold"
                   Foreground="#37474F" Margin="0,0,0,16"/>
        <TextBlock Text="{DynamicResource S.kebd16e}" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
        <TextBox x:Name="UserBox" Height="32" Padding="8,0" FontSize="12" Margin="0,0,0,12"/>
        <TextBlock Text="{DynamicResource S.k8e91b9}" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
        <TextBox x:Name="HostBox" Text="%" Height="32" Padding="8,0" FontSize="12" Margin="0,0,0,12"/>
        <TextBlock Text="{DynamicResource S.k024173}" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PwdBox" Height="32" Padding="8,0" FontSize="12" Margin="0,0,0,24"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource S.k625fb2}" Width="80" Height="32" Click="Cancel_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.k25f1a1}" Width="80" Height="32" Click="Ok_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="{StaticResource AccentBrush}"/>
        </StackPanel>
    </StackPanel>
</Window>
