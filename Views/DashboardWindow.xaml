<Window x:Class="MySQLManager.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.k39bcc7}" Height="600" Width="960"
        MinWidth="760" MinHeight="480"
        Background="#1A1B1E" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" Closed="Window_Closed" Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頂部控制列 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{DynamicResource S.k96e8f0}" FontSize="18" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           FontSize="11" Foreground="#9E9E9E" Margin="0,0,16,0"/>
                <TextBlock Text="{DynamicResource S.ke160c7}" VerticalAlignment="Center"
                           FontSize="11" Foreground="#9E9E9E" Margin="0,0,6,0"/>
                <ComboBox x:Name="IntervalCombo" Width="80" Height="28"
                          Background="#2C2D30" Foreground="White"
                          SelectionChanged="IntervalCombo_Changed">
                    <ComboBoxItem Content="{DynamicResource S.2579d86}"  Tag="2"/>
                    <ComboBoxItem Content="{DynamicResource S.52c36fe}"  Tag="5" IsSelected="True"/>
                    <ComboBoxItem Content="{DynamicResource S.104f60a7}" Tag="10"/>
                    <ComboBoxItem Content="{DynamicResource S.30c8772e}" Tag="30"/>
                </ComboBox>
                <Button x:Name="StartStopBtn" Content="{DynamicResource S.kd7ed22}" Width="80" Height="28"
                        Margin="8,0,0,0" Click="StartStop_Click"
                        Background="#3C4043" Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </DockPanel>

        <!-- 指標卡片列 -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#2C2D30" CornerRadius="10" Padding="16,14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="QPS" FontSize="10" Foreground="#9E9E9E"/>
                    <TextBlock x:Name="QpsCard" Text="—" FontSize="26" FontWeight="Bold" Foreground="#4DA3FF"/>
                    <TextBlock Text="{DynamicResource S.ke7cdf2}" FontSize="9" Foreground="#616161"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#2C2D30" CornerRadius="10" Padding="16,14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource S.k221c5f}" FontSize="10" Foreground="#9E9E9E"/>
                    <TextBlock x:Name="ConnCard" Text="—" FontSize="26" FontWeight="Bold" Foreground="#66BB6A"/>
                    <TextBlock Text="{DynamicResource S.k614704}" FontSize="9" Foreground="#616161"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#2C2D30" CornerRadius="10" Padding="16,14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource S.k4f2404}" FontSize="10" Foreground="#9E9E9E"/>
                    <TextBlock x:Name="ReadCard" Text="—" FontSize="26" FontWeight="Bold" Foreground="#FFA726"/>
                    <TextBlock Text="{DynamicResource S.Innodb0a37d8}" FontSize="9" Foreground="#616161"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="#2C2D30" CornerRadius="10" Padding="16,14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource S.k43c4f8}" FontSize="10" Foreground="#9E9E9E"/>
                    <TextBlock x:Name="WriteCard" Text="—" FontSize="26" FontWeight="Bold" Foreground="#EF5350"/>
                    <TextBlock Text="{DynamicResource S.Innodb0a37d8}" FontSize="9" Foreground="#616161"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="#2C2D30" CornerRadius="10" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="{DynamicResource S.kf62587}" FontSize="10" Foreground="#9E9E9E"/>
                    <TextBlock x:Name="SlowCard" Text="—" FontSize="26" FontWeight="Bold" Foreground="#AB47BC"/>
                    <TextBlock Text="{DynamicResource S.kce8a96}" FontSize="9" Foreground="#616161"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 折線圖區域 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#2C2D30" CornerRadius="10" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource S.QPS6bef55}" FontSize="12" FontWeight="SemiBold"
                               Foreground="#E0E0E0" Margin="0,0,0,10"/>
                    <Canvas Grid.Row="1" x:Name="QpsCanvas" ClipToBounds="True"/>
                </Grid>
            </Border>
            <Border Grid.Column="2" Background="#2C2D30" CornerRadius="10" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource S.InnoDB902f7f}" FontSize="12" FontWeight="SemiBold"
                               Foreground="#E0E0E0" Margin="0,0,0,10"/>
                    <Canvas Grid.Row="1" x:Name="IoCanvas" ClipToBounds="True"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
