<Window x:Class="MySQLManager.Views.TableSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.ked9ffd}" Height="600" Width="860"
        MinWidth="640" MinHeight="460"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 資料庫/表選擇 -->
            <RowDefinition Height="Auto"/>  <!-- 搜尋條件建立器 -->
            <RowDefinition Height="Auto"/>  <!-- 生成的 SQL -->
            <RowDefinition Height="*"/>     <!-- 結果 -->
            <RowDefinition Height="Auto"/>  <!-- 狀態 -->
        </Grid.RowDefinitions>

        <!-- 資料庫/表選擇 -->
        <Border Grid.Row="0" Background="#F0F2F5" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource S.k2801a2}" Foreground="#78909C" FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding Databases}"
                              SelectedItem="{Binding SelectedDatabase}"
                              Background="#E8ECF0" Foreground="White"
                              BorderBrush="#9E9E9E" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource S.k7b5e7c}" Foreground="#78909C" FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding Tables}"
                              SelectedItem="{Binding SelectedTable}"
                              Background="#E8ECF0" Foreground="White"
                              BorderBrush="#9E9E9E" Padding="6,4"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource S.k0f4e75}" Foreground="#78909C" FontSize="11" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding PageSizes}"
                              SelectedItem="{Binding SelectedPageSize}"
                              Width="80" Background="#E8ECF0" Foreground="White"
                              BorderBrush="#9E9E9E" Padding="6,4"/>
                </StackPanel>
                <Button Grid.Column="3" Content="{DynamicResource S.ka990af}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Bottom"
                        Click="LoadColumns_Click"/>
            </Grid>
        </Border>

        <!-- 條件建立器 -->
        <Border Grid.Row="1" Background="#EEF4FF" Padding="12,8"
                Visibility="{Binding HasColumns, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource S.k8f38f8}"     Foreground="#78909C" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{DynamicResource S.k1d7ea3}"     Foreground="#78909C" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock Grid.Column="2" Text="{DynamicResource S.kfe7509}"       Foreground="#78909C" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock Grid.Column="3" Text="{DynamicResource S.kc360e9}"     Foreground="#78909C" FontSize="11" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Grid.Column="4" Text="AND/OR"   Foreground="#78909C" FontSize="11" VerticalAlignment="Center" Margin="8,0"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Conditions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding DataContext.ColumnNames,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding ColumnName}"
                                          Background="#F0F2F5" Foreground="White"
                                          BorderBrush="#9E9E9E" Padding="4,3" FontSize="12"/>
                                <ComboBox Grid.Column="1" Margin="4,0"
                                          ItemsSource="{Binding DataContext.Operators,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding Operator}"
                                          Background="#F0F2F5" Foreground="White"
                                          BorderBrush="#9E9E9E" Padding="4,3" FontSize="12"/>
                                <TextBox Grid.Column="2" Margin="0,0,4,0"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#F0F2F5" Foreground="White"
                                         BorderBrush="#9E9E9E" Padding="6,4" FontSize="12"/>
                                <ComboBox Grid.Column="3" Margin="4,0"
                                          ItemsSource="{Binding DataContext.SortOrders,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding SortOrder}"
                                          Background="#F0F2F5" Foreground="White"
                                          BorderBrush="#9E9E9E" Padding="4,3" FontSize="11"/>
                                <ComboBox Grid.Column="4" Margin="4,0"
                                          ItemsSource="{Binding DataContext.LogicOps,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding LogicOp}"
                                          Background="#F0F2F5" Foreground="White"
                                          BorderBrush="#9E9E9E" Padding="4,3" FontSize="11"/>
                                <Button Grid.Column="5" Content="✕"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#D93025" Padding="2,0"
                                        Click="RemoveCondition_Click"
                                        Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="{DynamicResource S.k345841}" Click="AddCondition_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#9E9E9E" Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource S.F5c6e825}" Click="Search_Click"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource S.k4403fc}" Click="Clear_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#9E9E9E"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 生成的 SQL 預覽 -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="12,6"
                Visibility="{Binding GeneratedSql, Converter={StaticResource NullToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding GeneratedSql}"
                           Foreground="#1976D2" FontFamily="Consolas" FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1" Content="{DynamicResource S.k2e43a2}" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#9E9E9E" Padding="8,2"
                        Click="CopySql_Click"/>
            </Grid>
        </Border>

        <!-- 結果 DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding ResultData}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Background="Transparent"
                  Foreground="#37474F"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#F0F2F5"
                  VerticalGridLinesBrush="#F0F2F5"
                  HeadersVisibility="Column"
                  BorderThickness="0"
                  FontFamily="Consolas" FontSize="11"
                  RowBackground="Transparent"
                  AlternatingRowBackground="#FAFBFC">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                    <Setter Property="Background"   Value="#F0F2F5"/>
                    <Setter Property="Foreground"   Value="#1976D2"/>
                    <Setter Property="FontWeight"   Value="SemiBold"/>
                    <Setter Property="Padding"      Value="8,5"/>
                    <Setter Property="BorderBrush"  Value="#E8ECF0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="#F0F2F5" Padding="12,5">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#78909C" FontSize="11"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="◀" Click="PrevPage_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#9E9E9E" Padding="8,2" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding PageLabel}"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="▶" Click="NextPage_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#9E9E9E" Padding="8,2"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
