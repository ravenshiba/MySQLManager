<Window x:Class="MySQLManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MySQLManager.ViewModels"
        xmlns:views="clr-namespace:MySQLManager.Views"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="MySQL Manager" Height="760" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 工具列 Row 0 -->
            <RowDefinition Height="Auto"/>  <!-- 工具列 Row 1: 主題/語言 -->
            <RowDefinition Height="*"/>     <!-- 主體 Row 2 -->
            <RowDefinition Height="Auto"/>  <!-- 狀態列 Row 3 -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             TOOLBAR  (漸層背景 + 分群設計)
        ═══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource ToolbarGradientBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="10,7">
            <Grid>
                <!-- 左側：功能按鈕群 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Logo 標誌 -->
                    <Border CornerRadius="6" Padding="6,5" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1976D2" Offset="0"/>
                                <GradientStop Color="#7C4DFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="⚡" FontSize="14" Foreground="White" Margin="0"/>
                    </Border>

                    <!-- 群組 1：連線 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ConnectCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="{StaticResource AccentBrush}"
                                    Padding="8,5" ToolTip="{DynamicResource S.CtrlN681622}"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="13" Margin="0,0,5,0"/>
                                    <TextBlock Text="{DynamicResource S.kb2e9aa}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DisconnectCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Padding="8,5" ToolTip="{DynamicResource S.kbb672f}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✖" FontSize="11" Margin="0,0,5,0"/>
                                    <TextBlock Text="{DynamicResource S.k66dc8a}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 群組 2：查詢 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding NewQueryTabCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="{StaticResource SuccessBrush}"
                                    Padding="8,5" ToolTip="{DynamicResource S.CtrlTab22a6}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="＋" FontSize="13" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k9153a3}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RefreshTreeCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Padding="8,5" ToolTip="{DynamicResource S.F5c494a3}" BorderThickness="0">
                                <TextBlock Text="🔄" FontSize="13"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 群組 3：設計工具 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Click="SchemaCompare_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#CE93D8"
                                    Padding="8,5" ToolTip="{DynamicResource S.kfd81f4}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚖" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.kfd81f4}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="DataDiff_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#80CBC4"
                                    Padding="8,5" ToolTip="{DynamicResource S.k7e2c4c}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔀" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.kb994f1}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="RoutineEditor_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#CE93D8"
                                    Padding="8,5" ToolTip="Stored Procedure / Function" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Routine" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="Explain_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#80DEEA"
                                    Padding="8,5" ToolTip="{DynamicResource S.EXPLAIN0ec913}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="EXPLAIN" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 群組 4：資料工具 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Click="CsvImport_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#A5D6A7"
                                    Padding="8,5" ToolTip="{DynamicResource S.CSV922196}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k0b5fbe}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="TableSearch_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#A5D6A7"
                                    Padding="8,5" ToolTip="{DynamicResource S.ked9ffd}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k4a74cf}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="Backup_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#FFCC80"
                                    Padding="8,5" ToolTip="{DynamicResource S.k5c71af}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k1828ca}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 群組 5：監控 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3">
                        <Button Click="Monitor_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="Transparent" Foreground="#80DEEA"
                                Padding="8,5" ToolTip="{DynamicResource S.k3803d9}" BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📡" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource S.k7e9b2e}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- 群組 6：分析工具 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Click="SlowQuery_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#FFAB40"
                                    Padding="8,5" ToolTip="{DynamicResource S.k2aa6ed}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🐢" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.kf62587}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="LockAnalysis_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#EF9A9A"
                                    Padding="8,5" ToolTip="{DynamicResource S.Lock5510e9}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔒" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Lock" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="CrossConnect_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#CE93D8"
                                    Padding="8,5" ToolTip="{DynamicResource S.k9b6431}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔀" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.ka3c4f9}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="TableStats_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#80CBC4"
                                    Padding="8,5" ToolTip="{DynamicResource S.kfd0ab2}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k0c700c}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 群組 7：開發工具 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Click="CrudGenerator_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#CE93D8"
                                    Padding="8,5" ToolTip="{DynamicResource S.CRUD534123}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="CRUD" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="AuditLog_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#B0BEC5"
                                    Padding="8,5" ToolTip="{DynamicResource S.AuditLog63004c}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Log" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>


                    <!-- 群組 8：AI 與工具 -->
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="6" Padding="3,3" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Click="AiChat_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#A5D6A7"
                                    Padding="8,5" ToolTip="{DynamicResource S.AISQLc2e42b}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🤖" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.AI318e1b}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="Snippets_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#FFF176"
                                    Padding="8,5" ToolTip="{DynamicResource S.SQL74aca8}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📚" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k80e514}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="ScheduledBackup_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#FFCC80"
                                    Padding="8,5" ToolTip="{DynamicResource S.k77aa6c}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏰" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.kd5e76b}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="UserManagement_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#80DEEA"
                                    Padding="8,5" ToolTip="{DynamicResource S.k9ece0a}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.kab1904}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="Dashboard_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#CE93D8"
                                    Padding="8,5" ToolTip="{DynamicResource S.k39bcc7}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k743e9c}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Click="SqlFormatOptions_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="Transparent" Foreground="#A5D6A7"
                                    Padding="8,5" ToolTip="{DynamicResource S.SQLae3bd4}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{DynamicResource S.k5e70ab}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>



                                        <!-- 載入動畫 -->
                    <Border Width="60" Margin="10,0,0,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar IsIndeterminate="True" Height="3"
                                     Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                </StackPanel>



                <!-- 右側：版本資訊 / 狀態 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}">
                    <Border Background="{StaticResource DeepBrush}" CornerRadius="4" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6"
                                     Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ServerVersion}"
                                       Foreground="White"
                                       FontSize="11" FontFamily="Consolas"/>
                            <TextBlock Text="  |  " Foreground="#FFFFFF" FontSize="11"/>
                            <TextBlock Text="{Binding ConnectedUser}"
                                       Foreground="#BBDEFB"
                                       FontSize="11"/>
                            <TextBlock Text="@" Foreground="#FFFFFF" FontSize="11"/>
                            <TextBlock Text="{Binding ConnectedHost}"
                                       Foreground="#BBDEFB"
                                       FontSize="11" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 工具列第二行：主題色彩 + 語言切換 ═══ -->
        <Border Grid.Row="1"
                Background="{StaticResource ToolbarGradientBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="10,4">
            <DockPanel LastChildFill="False">
                <!-- 左側說明 -->
                <TextBlock DockPanel.Dock="Left"
                           Text="外觀設定"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <!-- 深色/淺色模式 -->
                <Button DockPanel.Dock="Left"
                        x:Name="ThemeBtn"
                        Click="ToggleTheme_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="8,3" Margin="0,0,4,0"
                        ToolTip="深色/淺色模式切換"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ThemeBtnIcon" Text="🌙" FontSize="13"/>
                        <TextBlock Text=" 深色模式" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 色彩分隔 -->
                <Separator DockPanel.Dock="Left" Width="1"
                           Background="{StaticResource BorderBrush}" Margin="4,2"/>
                <TextBlock DockPanel.Dock="Left" Text="主題色彩："
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="4,0,6,0"/>
                <Border DockPanel.Dock="Left" Width="18" Height="18" CornerRadius="9" Margin="2,0"
                        Background="#1976D2" Cursor="Hand" ToolTip="藍色（預設）"
                        MouseLeftButtonDown="SetAccentBlue_Click"/>
                <Border DockPanel.Dock="Left" Width="18" Height="18" CornerRadius="9" Margin="2,0"
                        Background="#2E7D32" Cursor="Hand" ToolTip="綠色"
                        MouseLeftButtonDown="SetAccentGreen_Click"/>
                <Border DockPanel.Dock="Left" Width="18" Height="18" CornerRadius="9" Margin="2,0"
                        Background="#7B1FA2" Cursor="Hand" ToolTip="紫色"
                        MouseLeftButtonDown="SetAccentPurple_Click"/>
                <Border DockPanel.Dock="Left" Width="18" Height="18" CornerRadius="9" Margin="2,0"
                        Background="#E65100" Cursor="Hand" ToolTip="橘色"
                        MouseLeftButtonDown="SetAccentOrange_Click"/>
                <Border DockPanel.Dock="Left" Width="18" Height="18" CornerRadius="9" Margin="2,0"
                        Background="#C62828" Cursor="Hand" ToolTip="紅色"
                        MouseLeftButtonDown="SetAccentRed_Click"/>
                <!-- 語言分隔 -->
                <Separator DockPanel.Dock="Left" Width="1"
                           Background="{StaticResource BorderBrush}" Margin="8,2"/>
                <TextBlock DockPanel.Dock="Left" Text="語言："
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,6,0"/>
                <Button DockPanel.Dock="Left" x:Name="LangZhBtn" Content="繁中"
                        Width="36" Height="24" FontSize="11"
                        FontWeight="Bold" Foreground="Black"
                        Margin="2,0" Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="LangZh_Click" ToolTip="繁體中文"/>
                <Button DockPanel.Dock="Left" x:Name="LangEnBtn" Content="EN"
                        Width="32" Height="24" FontSize="11"
                        FontWeight="Bold" Foreground="Black"
                        Margin="2,0" Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="LangEn_Click" ToolTip="English"/>
                <Button DockPanel.Dock="Left" x:Name="LangJaBtn" Content="日本語"
                        Width="40" Height="24" FontSize="11"
                        FontWeight="Bold" Foreground="Black"
                        Margin="2,0" Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="LangJa_Click" ToolTip="日本語"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════
             主體
        ═══════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="268" MinWidth="180" MaxWidth="500"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── 左側面板 ─── -->
            <Border Grid.Column="0" Background="{StaticResource SidebarGradientBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 連線 Session Tabs -->
                        <RowDefinition Height="Auto"/>  <!-- 側邊欄標題 + 搜尋 -->
                        <RowDefinition Height="Auto"/>  <!-- 搜尋結果計數 -->
                        <RowDefinition Height="*"/>     <!-- 樹狀 / 搜尋結果 -->
                    </Grid.RowDefinitions>

                    <!-- 連線 Session Tabs -->
                    <Border Grid.Row="0"
                            BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                            Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Session Tab 列 -->
                            <ScrollViewer Grid.Column="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Height="34">
                                <ItemsControl ItemsSource="{Binding Sessions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="SessionTab"
                                                    Padding="8,0,4,0" Cursor="Hand"
                                                    MinWidth="80" MaxWidth="140"
                                                    BorderThickness="0,0,1,0"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Height="34">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#EEF4FF"/>
                                                                <Setter Property="BorderThickness" Value="0,2,1,0"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <!-- Click 切換 Session -->
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.SwitchSessionCommand,
                                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding StatusDot}"
                                                               FontSize="8" VerticalAlignment="Center"
                                                               Margin="0,0,4,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding TabTitle}"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <Button Grid.Column="2"
                                                            Content="×" FontSize="11"
                                                            Width="16" Height="16"
                                                            Margin="3,0,0,0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{StaticResource TextDimBrush}"
                                                            Cursor="Hand" Padding="0"
                                                            Command="{Binding DataContext.CloseSessionCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <!-- 新增連線按鈕 -->
                            <Button Grid.Column="1"
                                    Width="34" Height="34"
                                    Content="＋"
                                    FontSize="16"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource AccentBrush}"
                                    Cursor="Hand"
                                    Command="{Binding ConnectCommand}"
                                    ToolTip="{DynamicResource S.k3340e2}"/>
                        </Grid>
                    </Border>

                    <!-- 側邊欄標題 + 搜尋 -->
                    <Border Grid.Row="1"
                            BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                            Padding="10,10,10,8">
                        <StackPanel>
                            <!-- 標題列 -->
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <!-- 漸層小方塊 icon -->
                                    <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1976D2" Offset="0"/>
                                                <GradientStop Color="#7C4DFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="{DynamicResource S.k861b12}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- 搜尋框 -->
                            <Grid>
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="28,6,28,6"
                                         FontSize="12"
                                         KeyDown="SearchBox_KeyDown"/>
                                <TextBlock Text="🔍" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           IsHitTestVisible="False"
                                           Foreground="#FFFFFF"/>
                                <Button Content="✕" FontSize="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,6,0"
                                        Width="16" Height="16"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#FFFFFF"
                                        Cursor="Hand"
                                        Visibility="{Binding SearchText, Converter={StaticResource NullToVisibility},
                                                     ConverterParameter=empty}"
                                        Click="ClearSearch_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 搜尋結果計數 -->
                    <Border Grid.Row="2"
                            Padding="10,5"
                            Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#EEF4FF" Offset="0"/>
                                <GradientStop Color="#F7F8FA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding SearchResultCount}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"/>
                    </Border>

                    <!-- 樹狀結構 -->
                    <TreeView Grid.Row="3"
                              x:Name="DbTreeView"
                              ItemsSource="{Binding TreeNodes}"
                              Background="Transparent" BorderThickness="0"
                              Padding="4,4"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              Visibility="{Binding IsSearching, Converter={StaticResource InverseBoolToVisibility}}">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="Expanded"              Handler="TreeItem_Expanded"/>
                                <EventSetter Event="MouseRightButtonDown"  Handler="TreeItem_RightClick"/>
                                <EventSetter Event="MouseDoubleClick"      Handler="TreeItem_DoubleClick"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu Opened="ContextMenu_Opened"
                                                     Background="{StaticResource SecondaryBrush}"
                                                     BorderBrush="{StaticResource BorderBrightBrush}"
                                                     BorderThickness="1">
                                            <ContextMenu.Resources>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Padding" Value="10,6"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                </Style>
                                            </ContextMenu.Resources>
                                            <MenuItem Header="{DynamicResource S.Eventa02e5f}" Tag="EventScheduler" Click="ContextMenu_Click"/>
                                            <MenuItem Header="{DynamicResource S.k3b68b9}" Tag="CreateTable" Click="ContextMenu_Click"/>
                                            <MenuItem Header="{DynamicResource S.k8814a2}"     Tag="Refresh"     Click="ContextMenu_Click"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource S.k52f6f1}"  Tag="DesignTable"  Click="ContextMenu_Click"/>
                                            <MenuItem Header="{DynamicResource S.ke1fce3}"    Tag="QueryTable"   Click="ContextMenu_Click"/>
                                            <MenuItem Header="{DynamicResource S.ERD5e1ef2}"  Tag="ShowErd"      Click="ContextMenu_Click"
                                                      Foreground="{StaticResource AccentBrush}"/>
                                            <MenuItem Header="{DynamicResource S.k661387}"    Tag="SearchData"   Click="ContextMenu_Click"/>
                                            <MenuItem Header="{DynamicResource S.k7b4cc4}"    Tag="DataDiff"     Click="ContextMenu_Click"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource S.k319a07}"  Tag="DropTable"    Click="ContextMenu_Click"
                                                      Foreground="{StaticResource ErrorBrush}"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource S.k9bc013}"  Tag="TableStats"  Click="ContextMenu_Click"/>
                                            <MenuItem Header="{DynamicResource S.CRUD8ec232}"   Tag="CrudTable"   Click="ContextMenu_Click"/>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <!-- 彩色小圓點依節點類型 -->
                                    <TextBlock Text="{Binding Icon}" FontSize="13"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- 搜尋結果列表 -->
                    <ListBox Grid.Row="3"
                             x:Name="SearchResultList"
                             ItemsSource="{Binding SearchResults}"
                             Background="Transparent" BorderThickness="0"
                             Padding="4,4"
                             Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}"
                             MouseDoubleClick="SearchResult_DoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                    <TextBlock Text="{Binding Icon}" FontSize="13"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13"/>
                                        <TextBlock Text="{Binding Path}"
                                                   Foreground="#FFFFFF"
                                                   FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 分隔線 -->
            <GridSplitter Grid.Column="1" Width="3"
                          Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Stretch"/>

            <!-- 右側：查詢分頁 -->
            <Grid Grid.Column="2" Background="{StaticResource DeepBrush}">
                <TabControl ItemsSource="{Binding QueryTabs}"
                            SelectedItem="{Binding ActiveTab}"
                            Background="{StaticResource DeepBrush}"
                            BorderThickness="0"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <!-- 雙擊改名 -->
                                <TextBlock x:Name="TabLbl"
                                           Text="{Binding TabTitle}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12" Margin="0,0,4,0"
                                           Cursor="IBeam"
                                           MouseLeftButtonDown="TabLabel_MouseDown"
                                           ToolTip="{DynamicResource S.k9debb7}"/>
                                <TextBox x:Name="TabEditBox"
                                         Text="{Binding TabTitle, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Margin="0,0,4,0"
                                         MinWidth="900" MaxWidth="200"
                                         Visibility="Collapsed"
                                         LostFocus="TabEditBox_LostFocus"
                                         KeyDown="TabEditBox_KeyDown"/>
                                <Button Content="×" FontSize="13"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Padding="2,0" Cursor="Hand"
                                        Command="{Binding DataContext.CloseTabCommand,
                                                  RelativeSource={RelativeSource AncestorType=TabControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <views:QueryTabView DataContext="{Binding}"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <!-- 未連線提示 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibility}}">
                    <!-- 大圓形背景 -->
                    <Border Width="100" Height="100" CornerRadius="50"
                            HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#EEF4FF" Offset="0"/>
                                <GradientStop Color="#FAFBFC" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                        <TextBlock Text="⚡" FontSize="42"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource S.MySQL2e219c}"
                               FontSize="20" FontWeight="Light"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource S.CtrlN0a1975}"
                               FontSize="13"
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>
                    <Button Command="{Binding ConnectCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Center"
                            Padding="28,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource S.kd040ec}" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════
             STATUS BAR  (豐富資訊列)
        ═══════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource StatusBarGradientBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="12,0" Height="28">
            <Grid>
                <!-- 左側：狀態訊息 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右側：連線指示器 + 伺服器資訊 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!-- 伺服器版本 (連線後顯示) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,16,0">
                        <TextBlock Text="{Binding SelectedDatabase}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11" FontFamily="Consolas"
                                   Visibility="{Binding SelectedDatabase, Converter={StaticResource NullToVisibility}}"/>
                        <TextBlock Text="  |  " Foreground="#FFFFFF"
                                   FontSize="11"
                                   Visibility="{Binding SelectedDatabase, Converter={StaticResource NullToVisibility}}"/>
                        <TextBlock Text="{Binding ServerVersion}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontFamily="Consolas"/>
                    </StackPanel>

                    <!-- 連線狀態燈 -->
                    <Border CornerRadius="3" Padding="8,2">
                        <StackPanel Orientation="Horizontal">
                            <!-- 狀態燈 (含光暈效果) -->
                            <Ellipse Width="7" Height="7"
                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                                <Ellipse.Effect>
                                    <BlurEffect Radius="3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Width="5" Height="5"
                                     VerticalAlignment="Center" Margin="-8,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="未連線"/>
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Text"       Value="已連線"/>
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
