<Window x:Class="MySQLManager.Views.ResultCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.kcdc2c0}" Height="620" Width="1060"
        MinWidth="780" MinHeight="480"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 控制列 -->
        <Border Grid.Row="0" Background="{StaticResource DeepBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                Padding="14,10">
            <DockPanel>
                <TextBlock Text="{DynamicResource S.k64571d}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource S.k509eca}" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <ComboBox x:Name="LeftCombo" Width="200" Height="28"
                              SelectionChanged="ComboChanged" FontSize="11"
                              DisplayMemberPath="Label"/>
                    <TextBlock Text="{DynamicResource S.k9b7397}" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="16,0,4,0"/>
                    <ComboBox x:Name="RightCombo" Width="200" Height="28"
                              SelectionChanged="ComboChanged" FontSize="11"
                              DisplayMemberPath="Label"/>
                    <Button Content="{DynamicResource S.k81b3fa}" Click="HighlightDiff_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="{StaticResource AccentBrush}"
                            Padding="12,6" Margin="12,0,0,0" Height="28"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 並排網格 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#E8F0FE" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource S.k63f13a}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="#1A73E8"/>
                        <TextBlock x:Name="LeftRowCount" FontSize="11" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <DataGrid Grid.Row="1" x:Name="LeftGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True" FontSize="11"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          BorderThickness="0"/>
            </Grid>

            <GridSplitter Grid.Column="1" Width="6"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- 右側 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#FEF3E2" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource S.k799475}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="#E65100"/>
                        <TextBlock x:Name="RightRowCount" FontSize="11" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <DataGrid Grid.Row="1" x:Name="RightGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True" FontSize="11"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          BorderThickness="0"/>
            </Grid>
        </Grid>

        <!-- 狀態列 -->
        <Border Grid.Row="2" Padding="14,8"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource DeepBrush}">
            <TextBlock x:Name="DiffSummary" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Window>
