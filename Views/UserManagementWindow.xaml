<Window x:Class="MySQLManager.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MySQLManager.Views"
        Title="{DynamicResource S.k9ece0a}" Height="660" Width="960"
        MinWidth="720" MinHeight="520"
        Background="#F0F2F5" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:MW_BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <local:MW_InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <local:MW_NullToVisibilityConverter        x:Key="NullToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 左側：使用者清單 ══ -->
        <Grid Grid.Column="0" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource DeepBrush}"
                    BorderThickness="0,0,1,1" BorderBrush="{StaticResource BorderBrush}"
                    Padding="14,12">
                <TextBlock Text="{DynamicResource S.k00b728}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Border>

            <ListBox Grid.Row="1" x:Name="UserList"
                     BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}"
                     SelectionChanged="UserList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Username}" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Host, StringFormat='主機：{0}'}"
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="8" Padding="6,2"
                                    Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}">
                                <Border.Background>
                                    <SolidColorBrush Color="#FFF3E0"/>
                                </Border.Background>
                                <TextBlock Text="{DynamicResource S.k789bb3}" FontSize="9" Foreground="#E65100"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="10,8" Orientation="Horizontal">
                <Button Content="{DynamicResource S.kd1dbe9}" Click="AddUser_Click"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource AccentBrush}"
                        Padding="10,7" Margin="0,0,6,0"/>
                <Button Content="{DynamicResource S.kfba47c}" Click="DeleteUser_Click"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#D93025" Padding="10,7"/>
            </StackPanel>
        </Grid>

        <!-- ══ 右側：權限編輯 ══ -->
        <Grid Grid.Column="1">
            <!-- 空白提示 -->
            <StackPanel x:Name="EmptyHint"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="👤" FontSize="52" HorizontalAlignment="Center"
                           Foreground="#DADCE0"/>
                <TextBlock Text="{DynamicResource S.k5457d0}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- 編輯面板 -->
            <Grid x:Name="EditPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 使用者資訊列 -->
                <Border Grid.Row="0" Background="{StaticResource DeepBrush}"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                        Padding="16,12">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock x:Name="UserHeader" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="UserSubHeader" FontSize="11" Margin="0,3,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{DynamicResource S.kb57182}" Click="ChangePassword_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,6" Margin="0,0,6,0"/>
                            <Button x:Name="LockBtn" Content="{DynamicResource S.ke69715}"
                                    Click="ToggleLock_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,6"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 新增權限列 -->
                <Border Grid.Row="1" Padding="16,10"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                        Background="White">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource S.ke1f3a2}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="GrantDbCombo" Width="150" Height="30"
                                  IsEditable="True" FontSize="12" Padding="6,0"
                                  ToolTip="{DynamicResource S.k0eb8e0}"/>
                        <TextBlock Text="." VerticalAlignment="Center"
                                   FontSize="16" Margin="4,0"/>
                        <ComboBox x:Name="GrantTblCombo" Width="150" Height="30"
                                  IsEditable="True" FontSize="12" Padding="6,0"
                                  ToolTip="{DynamicResource S.k2ceb5f}"/>
                        <Button Content="{DynamicResource S.ka980c4}" Click="OpenGrantEditor_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="{StaticResource AccentBrush}"
                                Padding="12,6" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 權限清單 -->
                <DataGrid Grid.Row="2" x:Name="PrivGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          Background="White"
                          BorderThickness="0"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource S.k2801a2}" Binding="{Binding Database}" Width="160"/>
                        <DataGridTextColumn Header="{DynamicResource S.k7b5e7c}" Binding="{Binding Table}"    Width="160"/>
                        <DataGridTextColumn Header="{DynamicResource S.kf492b1}" Binding="{Binding GrantsDisplay}" Width="*"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- 底部按鈕 -->
                <Border Grid.Row="3" Padding="16,10"
                        BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource DeepBrush}">
                    <DockPanel>
                        <Button DockPanel.Dock="Left" Content="{DynamicResource S.k7644f0}"
                                Click="RevokeSelected_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="#D93025" Padding="12,7"/>
                        <Button DockPanel.Dock="Right" Content="{DynamicResource S.GRANTSQLd5ae75}"
                                Click="CopyGrantSql_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,7"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
