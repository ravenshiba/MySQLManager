<UserControl
x:Class="MySQLManager.Views.QueryTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:helpers="clr-namespace:MySQLManager.Helpers"
             xmlns:local="clr-namespace:MySQLManager.Views"
             Background="White">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>          <!-- 0: 工具列 -->
            <RowDefinition Height="Auto"/>          <!-- 1: AI 面板 -->
            <RowDefinition Height="Auto"/>          <!-- 2: 搜尋取代列 -->
            <RowDefinition Height="3*" MinHeight="120"/> <!-- 3: SQL 編輯器 -->
            <RowDefinition Height="5"/>             <!-- 3: Splitter -->
            <RowDefinition Height="2*" MinHeight="80"/>  <!-- 4: 結果 -->
            <RowDefinition Height="Auto"/>          <!-- 5: 狀態列 -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: 工具列 ═══ -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Vertical">

                <!-- 上排：主要操作（可水平捲動，防止重疊） -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled" Focusable="False">
                    <StackPanel Orientation="Horizontal" Margin="8,5,8,4">
                        <Button Content="{DynamicResource S.F5b0b266}"
                                Command="{Binding RunQueryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,4,0"/>
                        <Button Content="{DynamicResource S.k112e07}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" Margin="0,0,4,0"
                                ToolTip="{DynamicResource S.SQLCtrlO4b4793}"
                                Click="OpenSqlFile_Click"/>
                        <Button Content="{DynamicResource S.kdb212b}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" Margin="0,0,4,0"
                                ToolTip="{DynamicResource S.SQLCtrlS519a96}"
                                Click="SaveSqlFile_Click"/>
                        <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="4,3"/>
                        <TextBlock Text="{DynamicResource S.k4a4f21}" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="4,0,4,0" FontSize="12"/>
                        <TextBox Text="{Binding SelectedDatabase, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" Padding="5,3" VerticalAlignment="Center"/>
                        <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="6,3"/>
                        <Button Content="{DynamicResource S.k6aa4b3}"
                                Command="{Binding ShowHistoryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" Margin="0,0,4,0"
                                ToolTip="{DynamicResource S.CtrlHef419f}"/>
                        <Button Content="{DynamicResource S.k874133}"
                                Command="{Binding FormatSqlCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" Margin="0,0,4,0"
                                ToolTip="{DynamicResource S.SQLCtrlSf33db8}"/>
                        <Button Content="🤖 AI"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Foreground="#7C4DFF" BorderBrush="#7C4DFF"
                                Padding="8,4" Margin="0,0,4,0"
                                ToolTip="{DynamicResource S.AISQLa4e273}"
                                Click="AiPanel_Toggle"/>
                        <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="4,3"/>
                        <Button Content="{DynamicResource S.k3fa4cd}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" Margin="0,0,0,0"
                                ToolTip="{DynamicResource S.AI2d5290}"
                                Click="AiIndex_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 下排：匯出 + 結果操作 -->
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Background="{StaticResource PrimaryBrush}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled" Focusable="False">
                        <StackPanel Orientation="Horizontal" Margin="8,4">
                            <Button Content="📥 CSV"
                                    Command="{Binding ExportCsvCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Foreground="#1E8E3E" BorderBrush="#1E8E3E"
                                    Padding="8,3" Margin="0,0,4,0" ToolTip="{DynamicResource S.CSV8e7a80}"/>
                            <Button Content="📥 SQL"
                                    Command="{Binding ExportSqlCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Foreground="#1565C0" BorderBrush="#1565C0"
                                    Padding="8,3" Margin="0,0,4,0" ToolTip="{DynamicResource S.SQLINSER5ef371}"/>
                            <Button Content="📊 Excel"
                                    Command="{Binding ExportXlsxCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Foreground="#1E8E3E" BorderBrush="#1E8E3E"
                                    Padding="8,3" Margin="0,0,4,0" ToolTip="{DynamicResource S.Excel83110a}"/>
                            <Button Content="{DynamicResource S.k5e2db4}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Foreground="#1E8E3E" BorderBrush="#1E8E3E"
                                    Padding="8,3" Margin="0,0,4,0" ToolTip="{DynamicResource S.ka29740}"
                                    Click="OpenChart_Click"/>
                            <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="4,2"/>
                            <Button Content="{DynamicResource S.k926b38}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3" Margin="0,0,4,0" ToolTip="{DynamicResource S.kf8b4df}"
                                    Click="SaveSnapshot_Click"/>
                            <Button Content="{DynamicResource S.k8cfdac}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3" Margin="0,0,4,0" ToolTip="{DynamicResource S.k8b8145}"
                                    Click="CompareSnapshots_Click"/>
                            <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="4,2"/>
                            <Button Content="{DynamicResource S.kb68ce5}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3" Margin="0,0,4,0"
                                    ToolTip="{DynamicResource S.CtrlF98a3ab}"
                                    Click="ToggleFilter_Click"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>
        <!-- ═══ Row 1: AI 輔助 SQL 面板 ═══ -->
        <Border Grid.Row="1"
                Background="#F3F0FF"
                BorderBrush="#C5B4FF"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowAiPanel, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 提示輸入框 -->
                <TextBox Grid.Row="0" Grid.Column="0"
                         x:Name="AiPromptBox"
                         Text="{Binding AiPrompt, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="AiPromptBox_KeyDown"
                         Padding="8,6" FontSize="13"
                         Background="White" BorderBrush="#C5B4FF"
                         ToolTip="{DynamicResource S.SQL30e4c6a5}"/>

                <!-- 生成按鈕 -->
                <Button Grid.Row="0" Grid.Column="1"
                        Content="{DynamicResource S.SQL504afa}"
                        Command="{Binding AiGenerateCommand}"
                        IsEnabled="{Binding AiIsLoading, Converter={StaticResource InverseBool}}"
                        Margin="6,0,0,0" Padding="12,6"
                        Background="#7C4DFF" Foreground="White"
                        BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="R" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Row="0" Grid.Column="2"
                        Content="{DynamicResource S.k638f02}"
                        Command="{Binding AiExplainCommand}"
                        IsEnabled="{Binding AiIsLoading, Converter={StaticResource InverseBool}}"
                        Margin="4,0,0,0" Padding="10,6"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Foreground="#7C4DFF" BorderBrush="#C5B4FF"
                        FontSize="12"/>

                <Button Grid.Row="0" Grid.Column="3"
                        Content="⚙️" Width="28" Height="28"
                        Margin="4,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        BorderBrush="#C5B4FF"
                        ToolTip="{DynamicResource S.APIKey1061fb}"
                        Click="AiSettings_Click"/>

                <!-- 收藏庫按鈕 -->
                <Button Grid.Row="0" Grid.Column="0"
                        HorizontalAlignment="Left"
                        Content="{DynamicResource S.k715cd5}" Height="28"
                        Margin="0,0,0,0"
                        Padding="8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        ToolTip="{DynamicResource S.SQLCtrlS43cafe}"
                        Click="OpenSnippets_Click"/>

                <!-- AI 結果 -->
                <Border Grid.Row="1" Grid.ColumnSpan="4"
                        Margin="0,6,0,0"
                        Visibility="{Binding AiResult, Converter={StaticResource NullOrEmptyToVisibility}}">
                    <TextBlock Text="{Binding AiResult}"
                               FontFamily="Consolas, Courier New"
                               FontSize="12" Foreground="#4A3080"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Row 2: 搜尋取代列 ═══ -->
        <local:FindReplaceBar x:Name="FindReplace" Grid.Row="2"/>

        <!-- ═══ Row 2: SQL 編輯器 + 自動完成浮層 ═══ -->
        <Grid Grid.Row="3">
            <Border BorderBrush="#DADCE0" BorderThickness="0,0,0,1">
                <avalon:TextEditor x:Name="SqlEditor"
                                   FontFamily="Consolas, Courier New" FontSize="13"
                                   Background="White"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   ShowLineNumbers="True" WordWrap="False"/>
            </Border>

            <!-- 自動完成下拉 -->
            <Popup x:Name="CompletionPopup"
                   IsOpen="{Binding ShowCompletions}"
                   PlacementTarget="{Binding ElementName=SqlEditor}"
                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                <Border Background="White" BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="3"
                        MinWidth="320" MaxHeight="220">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <ListBox x:Name="CompletionList"
                             ItemsSource="{Binding Completions}"
                             SelectedItem="{Binding SelectedCompletion, Mode=TwoWay}"
                             Background="White" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12"
                             KeyDown="CompletionList_KeyDown"
                             MouseDoubleClick="CompletionList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" Width="16"/>
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="Medium" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"    Value="8,4"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D2E3FC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Popup>
        </Grid>

        <!-- Row 3: 可拖曳分隔線 -->
        <GridSplitter Grid.Row="4" Height="5"
                      Background="{StaticResource SecondaryBrush}"
                      HorizontalAlignment="Stretch"/>

        <!-- ═══ Row 4: 結果區 ═══ -->
        <Grid Grid.Row="5">
            <Grid Visibility="{Binding HasMultiResults, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 多結果集子 Tab 列 -->
                <Border Grid.Row="0"
                        Background="#F0F2F5"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                        Visibility="{Binding HasMultiResults, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel LastChildFill="False">
                        <!-- 左側：可捲動的 Tab 按鈕 -->
                        <ScrollViewer DockPanel.Dock="Left"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      MaxWidth="820">
                            <ItemsControl ItemsSource="{Binding MultiResults}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="SubTabBtn"
                                                Margin="2,4,0,0"
                                                Cursor="Hand"
                                                CornerRadius="6,6,0,0"
                                                BorderThickness="1,1,1,0"
                                                Padding="0">
                                            <Border.ToolTip>
                                                <StackPanel MaxWidth="420">
                                                    <TextBlock Text="{Binding Sql}" FontFamily="Consolas" FontSize="11"
                                                               Foreground="#333" TextWrapping="Wrap" MaxWidth="400"/>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                               Foreground="#888" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border.ToolTip>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.SelectResultCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8EAED"/>
                                                    <Setter Property="BorderBrush" Value="#DADCE0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Setter Property="BorderBrush" Value="#1A73E8"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="White"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal" Margin="10,5,12,5">
                                                <!-- 圖示 -->
                                                <TextBlock Text="{Binding TabIcon}"
                                                           FontSize="11" Margin="0,0,5,0"
                                                           VerticalAlignment="Center"/>
                                                <!-- Tab 標題 -->
                                                <StackPanel>
                                                    <TextBlock Text="{Binding TabLabel}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               FontFamily="Consolas">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#5F6368"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Foreground" Value="#1A73E8"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="9" Foreground="#9AA0A6"
                                                               Margin="0,-1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <!-- 右側：結果集總覽 -->
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="11" Foreground="#9AA0A6">
                            <Run Text="{Binding MultiResults.Count, Mode=OneWay, StringFormat=共 {0} 個結果集}"/>
                        </TextBlock>
                    </DockPanel>
                </Border>

                <!-- 非 SELECT 結果面板 (INSERT / UPDATE / DELETE / DDL) -->
                <Border Grid.Row="1"
                        Visibility="{Binding ShowNonSelectPanel, Converter={StaticResource BoolToVisibility}}"
                        Background="#F1F8E9" BorderThickness="0,0,0,1"
                        BorderBrush="#C8E6C9" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ActiveResult.SqlType,
                                               StringFormat='執行成功  ({0})'}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#2E7D32"/>
                            <TextBlock Text="{Binding NonSelectMessage}"
                                       FontSize="11" Foreground="#558B2F" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- SQL 預覽 -->
                        <Border Margin="24,0,0,0" Background="#E8F5E9"
                                CornerRadius="4" Padding="10,6">
                            <TextBlock Text="{Binding ActiveResult.Sql}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#1B5E20" MaxWidth="600"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ActiveResult.Sql}"/>
                        </Border>
                    </StackPanel>
                </Border>

                                <!-- 編輯工具列 -->
                <Border Grid.Row="3" Background="{StaticResource SecondaryBrush}"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding EditModeLabel}"
                                Command="{Binding ToggleEditCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0"/>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                            <Button Content="{DynamicResource S.k9d5ded}" Command="{Binding AddRowCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#1E8E3E" Margin="0,0,4,0"/>
                            <Button Content="{DynamicResource S.k42a6c6}" Command="{Binding DeleteRowCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#D93025" Margin="0,0,4,0"/>
                            <Separator Width="1" Background="#DADCE0" Margin="4,2"/>
                            <Button Content="{DynamicResource S.k22ef54}" Command="{Binding SaveChangesCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#1565C0" Margin="0,0,4,0"/>
                            <Button Content="{DynamicResource S.kc4487b}" Command="{Binding DiscardChangesCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#78909C" Margin="0,0,4,0"/>
                        </StackPanel>
                        <Border Background="#E65100" CornerRadius="3" Padding="8,3" Margin="8,0,0,0"
                                Visibility="{Binding HasPendingChanges, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{DynamicResource S.k9189b0}" Foreground="White" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Filter Bar -->
                <Border Grid.Row="4" x:Name="FilterBar"
                        Background="#F8F9FA" BorderThickness="0,1,0,1"
                        BorderBrush="{StaticResource BorderBrush}"
                        Visibility="Collapsed">
                    <DockPanel Margin="8,5">
                        <Button DockPanel.Dock="Right" Content="✕" Width="26" Height="26"
                                Click="FilterClose_Click" FontSize="11"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="4,0,0,0"
                                ToolTip="{DynamicResource S.ka27385}"/>
                        <Button DockPanel.Dock="Right" Content="{DynamicResource S.k4403fc}" Width="48" Height="26"
                                Click="FilterClear_Click" FontSize="11"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="4,0,0,0"/>
                        <ComboBox x:Name="FilterColumnCombo" DockPanel.Dock="Left"
                                  Width="150" Height="26" FontSize="11" Margin="0,0,6,0"/>
                        <ComboBox x:Name="FilterOpCombo" DockPanel.Dock="Left"
                                  Width="100" Height="26" FontSize="11" Margin="0,0,6,0">
                            <ComboBoxItem Content="{DynamicResource S.ke13556}" IsSelected="True"/>
                            <ComboBoxItem Content="{DynamicResource S.k5bece4}"/>
                            <ComboBoxItem Content="{DynamicResource S.k0eb646}"/>
                            <ComboBoxItem Content="{DynamicResource S.k578380}"/>
                            <ComboBoxItem Content="{DynamicResource S.k74e4f6}"/>
                            <ComboBoxItem Content="{DynamicResource S.k5cc9b9}"/>
                            <ComboBoxItem Content="{DynamicResource S.ka09147}"/>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource S.k235932}" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox x:Name="FilterBox" Height="26" FontSize="11"
                                 Padding="6,0" VerticalContentAlignment="Center"
                                 TextChanged="FilterBox_TextChanged"/>
                    </DockPanel>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="5" x:Name="ResultGrid"
                          Visibility="{Binding ShowNonSelectPanel,
                                       Converter={StaticResource InverseBoolToVisibility}}"
                          ItemsSource="{Binding ResultData}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="ResultGrid_AutoGeneratingColumn"
                          IsReadOnly="{Binding CanEdit, Converter={StaticResource InverseBool}}"
                          Background="White"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          VerticalGridLinesBrush="{StaticResource BorderBrush}"
                          HeadersVisibility="Column"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFBFC"
                          BorderThickness="0"
                          FontFamily="Consolas" FontSize="12"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          MouseDoubleClick="ResultGrid_DoubleClick"
                          BeginningEdit="ResultGrid_BeginningEdit"
                          CellEditEnding="ResultGrid_CellEditEnding"
                          MouseRightButtonDown="ResultGrid_RightClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu x:Name="GridContextMenu">
                            <!-- 複製 -->
                            <MenuItem Header="{DynamicResource S.k1ec042}"    Click="CopyCell_Click"/>
                            <MenuItem Header="{DynamicResource S.TSV89af26}"  Click="CopyRow_Click"/>
                            <MenuItem Header="{DynamicResource S.CSVf1c8fd}"  Click="CopyRowCsv_Click"/>
                            <MenuItem Header="{DynamicResource S.k4b23f7}"    Click="CopyColName_Click"/>
                            <Separator/>
                            <!-- 篩選 -->
                            <MenuItem Header="{DynamicResource S.WHEREf83ad9}"    Click="FilterEqual_Click"/>
                            <MenuItem Header="{DynamicResource S.WHERE4e9b3e}"   Click="FilterNotEqual_Click"/>
                            <MenuItem Header="{DynamicResource S.WHERELIK3a4fc1}" Click="FilterLike_Click"/>
                            <Separator/>
                            <!-- 查詢 -->
                            <MenuItem Header="{DynamicResource S.SELECTd1ff9c}"   Click="QuickSelect_Click"/>
                            <MenuItem Header="{DynamicResource S.Tab520a5c}"   Click="OpenNewTab_Click"/>
                            <Separator/>
                            <!-- 匯出 -->
                            <MenuItem Header="{DynamicResource S.CSVd5aa88}"        Click="ExportCsv_Click"/>
                            <MenuItem Header="{DynamicResource S.XLSX1e4da4}"       Click="ExportXlsx_Click"/>
                            <Separator/>
                            <MenuItem Header="{DynamicResource S.k168356}" x:Name="FkJumpMenu"
                                      Click="FkJump_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader"
                               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="Background"  Value="{StaticResource SecondaryBrush}"/>
                            <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                            <Setter Property="Padding"     Value="0"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Grid Background="{TemplateBinding Background}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="8"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                Text="{TemplateBinding Content}"
                                                Margin="8,5,4,5"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource AccentBrush}"
                                                VerticalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1"
                                                x:Name="FilterBtn"
                                                Content="▾" FontSize="10"
                                                Padding="3,1" Margin="0,2,2,2"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" ToolTip="{DynamicResource S.k4e3938}"
                                                Tag="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                Click="ColumnFilterBtn_Click"/>
                                            <Thumb Grid.Column="2"
                                                x:Name="PART_RightHeaderGripper"
                                                HorizontalAlignment="Right"
                                                Width="8" Cursor="SizeWE"
                                                Background="Transparent"
                                                BorderThickness="0,0,1,0"
                                                BorderBrush="{StaticResource BorderBrush}"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow"
                               BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF4FF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D2E3FC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                                <Trigger Property="IsEditing" Value="True">
                                    <Setter Property="Background" Value="#D2E3FC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                </DataGrid>

                <!-- ── 分頁列 ── -->
                <Border Grid.Row="5"
                        Visibility="{Binding ShowPager, Converter={StaticResource BoolToVisibility}}"
                        Background="#F8F9FA"
                        BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                        Padding="10,5">
                    <DockPanel>
                        <!-- 左：每頁筆數選擇 -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.k7d3658}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="PageSizeCombo"
                                      Width="72" Height="24" FontSize="11"
                                      SelectionChanged="PageSizeCombo_SelectionChanged">
                                <ComboBoxItem Content="100"  Tag="100"/>
                                <ComboBoxItem Content="250"  Tag="250"/>
                                <ComboBoxItem Content="500"  Tag="500"/>
                                <ComboBoxItem Content="1000" Tag="1000"/>
                                <ComboBoxItem Content="2000" Tag="2000"/>
                            </ComboBox>
                            <TextBlock Text="{DynamicResource S.ka4b797}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>

                        <!-- 右：翻頁按鈕 -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <!-- 首頁 -->
                            <Button Command="{Binding FirstPageCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="28" Height="24" Padding="0"
                                    FontSize="12" Content="«" ToolTip="{DynamicResource S.k0ab95d}"
                                    Margin="0,0,2,0"/>
                            <!-- 上一頁 -->
                            <Button Command="{Binding PrevPageCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="28" Height="24" Padding="0"
                                    FontSize="12" Content="‹" ToolTip="{DynamicResource S.k0b5d40}"
                                    Margin="0,0,6,0"/>
                            <!-- 頁碼輸入 -->
                            <TextBox x:Name="PageInputBox"
                                     Width="44" Height="24" FontSize="11"
                                     TextAlignment="Center" VerticalContentAlignment="Center"
                                     Text="{Binding CurrentPage, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                     KeyDown="PageInputBox_KeyDown"
                                     LostFocus="PageInputBox_LostFocus"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Padding="2,0"/>
                            <TextBlock Text="{Binding TotalPages, StringFormat=/ {0}}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="4,0,6,0"/>
                            <!-- 下一頁 -->
                            <Button Command="{Binding NextPageCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="28" Height="24" Padding="0"
                                    FontSize="12" Content="›" ToolTip="{DynamicResource S.k2ca9eb}"
                                    Margin="0,0,2,0"/>
                            <!-- 末頁 -->
                            <Button Command="{Binding LastPageCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="28" Height="24" Padding="0"
                                    FontSize="12" Content="»" ToolTip="{DynamicResource S.kdb6744}"/>
                        </StackPanel>

                        <!-- 中：範圍資訊 -->
                        <TextBlock Text="{Binding RowRangeInfo}"
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 無資料提示 -->
            <TextBlock Text="{DynamicResource S.SQL5c819f}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasMultiResults,
                                    Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- 忙碌遮罩 -->
            <Border Background="#AAFFFFFF"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                                 Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{DynamicResource S.k0f9c2c}" Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ Row 5: 狀態列 ═══ -->
        <Border Grid.Row="6" Padding="10,5">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}"   Value="True">
                            <Setter Property="Background" Value="#FEECEC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Background" Value="#D2E3FC"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ResultMessage}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="12" FontFamily="Consolas"/>
        </Border>
    </Grid>
</UserControl>
