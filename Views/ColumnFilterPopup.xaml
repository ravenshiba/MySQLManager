<UserControl x:Class="MySQLManager.Views.ColumnFilterPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="6"
            Effect="{x:Null}" Width="220">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search -->
            <TextBox Grid.Row="0" x:Name="SearchBox"
                     FontSize="12" Padding="6,4" Margin="0,0,0,6"
                     TextChanged="SearchBox_TextChanged"/>

            <!-- Select All -->
            <CheckBox Grid.Row="1" x:Name="SelectAllChk"
                      Content="{DynamicResource S.k179777}" FontSize="12" Margin="2,0,0,4"
                      Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>

            <!-- Value list -->
            <ListBox Grid.Row="2" x:Name="ValueList"
                     SelectionMode="Multiple"
                     FontSize="12"
                     BorderThickness="1"
                     BorderBrush="{StaticResource BorderBrush}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="{DynamicResource S.k4403fc}" Click="Clear_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                <Button Content="{DynamicResource S.kef987d}" Click="Apply_Click"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="10,4" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
