<Window x:Class="MySQLManager.Views.ChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.kb54f4a}" Width="860" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5"
        FontFamily="Segoe UI, Microsoft JhengHei">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 控制列 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource S.X690236}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <ComboBox x:Name="XAxisCombo" Width="140" Margin="4,0,12,0"
                          SelectionChanged="Options_Changed"/>
                <TextBlock Text="{DynamicResource S.Y0c5f64}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <ComboBox x:Name="YAxisCombo" Width="140" Margin="4,0,16,0"
                          SelectionChanged="Options_Changed"/>
                <TextBlock Text="{DynamicResource S.k22b7bf}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <ComboBox x:Name="ChartTypeCombo" Width="100" Margin="4,0,0,0"
                          SelectionChanged="Options_Changed">
                    <ComboBoxItem Content="{DynamicResource S.k1de453}" IsSelected="True"/>
                    <ComboBoxItem Content="{DynamicResource S.k4cea01}"/>
                    <ComboBoxItem Content="{DynamicResource S.k91912a}"/>
                </ComboBox>
                <TextBlock Text="{DynamicResource S.kc4e4b3}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           Margin="16,0,4,0"/>
                <ComboBox x:Name="LimitCombo" Width="70"
                          SelectionChanged="Options_Changed">
                    <ComboBoxItem Content="20" IsSelected="True"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="100"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- 圖表區域（用 Canvas 手繪） -->
        <Border Grid.Row="1" Background="White" Margin="0">
            <ScrollViewer x:Name="ChartScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="ChartCanvas" Background="White"
                        MinWidth="660" MinHeight="460"
                        SizeChanged="Canvas_SizeChanged"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
