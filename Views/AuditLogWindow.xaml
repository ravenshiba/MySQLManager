<Window x:Class="MySQLManager.Views.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.AuditLog538102}" Width="980"
        MinWidth="720" MinHeight="480" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5"
        FontFamily="Segoe UI, Microsoft JhengHei">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 篩選列 -->
            <RowDefinition Height="*"/>     <!-- 記錄列表 -->
            <RowDefinition Height="Auto"/>  <!-- SQL 預覽 -->
            <RowDefinition Height="Auto"/>  <!-- 底部列 -->
        </Grid.RowDefinitions>

        <!-- 篩選列 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SearchBox"
                         Padding="8,6" FontSize="12"
                         Text="" TextChanged="SearchBox_TextChanged"
                         ToolTip="{DynamicResource S.SQL38635d}"/>
                <ComboBox Grid.Column="1" x:Name="TypeFilter" Width="100"
                          Margin="8,0,0,0" SelectionChanged="TypeFilter_Changed">
                    <ComboBoxItem Content="{DynamicResource S.ka8b0c2}" IsSelected="True"/>
                    <ComboBoxItem Content="SELECT"/>
                    <ComboBoxItem Content="INSERT"/>
                    <ComboBoxItem Content="UPDATE"/>
                    <ComboBoxItem Content="DELETE"/>
                    <ComboBoxItem Content="DDL"/>
                </ComboBox>
                <Button Grid.Column="2" Content="{DynamicResource S.kb401bd}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Padding="10,6"
                        Click="Refresh_Click"/>
                <Button Grid.Column="3" Content="{DynamicResource S.k7a41a9}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#D93025"
                        Margin="8,0,0,0" Padding="10,6"
                        Click="Clear_Click"/>
            </Grid>
        </Border>

        <!-- 記錄列表 -->
        <DataGrid Grid.Row="1" x:Name="LogGrid"
                  Background="White"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFBFC"
                  BorderThickness="0"
                  FontFamily="Consolas" FontSize="12"
                  CanUserResizeRows="False"
                  SelectionChanged="LogGrid_SelectionChanged">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader"
                       BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                    <Setter Property="Background"  Value="{StaticResource SecondaryBrush}"/>
                    <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                    <Setter Property="Padding"     Value="8,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow"
                       BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EEF4FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#D2E3FC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource S.k883b81}"       Binding="{Binding TimeDisplay}" Width="110"/>
                <DataGridTemplateColumn Header="{DynamicResource S.kbd91f6}" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusIcon}"
                                       HorizontalAlignment="Center" FontSize="13"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource S.k84c1fa}" Width="65">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="#E8F0FE"/>
                                </Border.Background>
                                <TextBlock Text="{Binding SqlType}"
                                           Foreground="{Binding TypeColor}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource S.kb2e9aa}"       Binding="{Binding Connection}"  Width="120"/>
                <DataGridTextColumn Header="{DynamicResource S.k2801a2}"     Binding="{Binding Database}"    Width="100"/>
                <DataGridTextColumn Header="{DynamicResource S.SQLc5185e}"   Binding="{Binding SqlPreview}"  Width="*"/>
                <DataGridTextColumn Header="{DynamicResource S.ms2d6b58}"   Binding="{Binding ElapsedMs}"   Width="80"/>
                <DataGridTextColumn Header="{DynamicResource S.k48c28f}"     Binding="{Binding RowsAffected}" Width="65"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- SQL 完整內容 -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Background="#F4F6F9" Padding="12,8"
                MaxHeight="120"
                Visibility="{Binding ElementName=SqlFullText, Path=Text,
                             Converter={StaticResource NullOrEmptyToVisibility},
                             FallbackValue=Collapsed}"
                x:Name="SqlPreviewPanel">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="SqlFullText"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
                <Button Grid.Column="1"
                        Content="{DynamicResource S.SQL36a961}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Padding="10,6"
                        Click="CopySql_Click"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- 底部統計列 -->
        <Border Grid.Row="3"
                Background="{StaticResource StatusBarGradientBrush}"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatsText"
                           Foreground="White" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
