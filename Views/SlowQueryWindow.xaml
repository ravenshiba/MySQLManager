<Window x:Class="MySQLManager.Views.SlowQueryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.k6b1a76}" Width="1000"
        MinWidth="760" MinHeight="480" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5"
        FontFamily="Segoe UI, Microsoft JhengHei">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource S.kdfa6aa}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <ComboBox x:Name="ThresholdCombo" Width="80" Margin="4,0,12,0">
                        <ComboBoxItem Content="0.1"/>
                        <ComboBoxItem Content="0.5"/>
                        <ComboBoxItem Content="1" IsSelected="True"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                    </ComboBox>
                    <TextBlock Text="{DynamicResource S.k899c0c}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <ComboBox x:Name="SortCombo" Width="130" Margin="4,0,12,0"
                              SelectionChanged="Options_Changed">
                        <ComboBoxItem Content="{DynamicResource S.k7cd2c3}" IsSelected="True"/>
                        <ComboBoxItem Content="{DynamicResource S.kaa5f82}"/>
                        <ComboBoxItem Content="{DynamicResource S.k21773a}"/>
                        <ComboBoxItem Content="{DynamicResource S.k2b51ff}"/>
                    </ComboBox>
                    <Button Content="{DynamicResource S.kcd403e}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Analyze_Click" Padding="14,6"/>
                    <Button Content="{DynamicResource S.k5bdb91}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="8,0,0,0" Padding="10,6"
                            Click="Reset_Click"
                            ToolTip="{DynamicResource S.performa797ff3}"/>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            </Grid>
        </Border>

        <!-- 視覺化圖表 Canvas -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Canvas x:Name="ChartCanvas" Background="White"/>
                <Border x:Name="LoadingPanel" Background="#AAFFFFFF"
                        Visibility="{Binding IsLoading, FallbackValue=Collapsed}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{DynamicResource S.kee0b2c}" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="2" Height="5" Background="{StaticResource SecondaryBrush}"
                      HorizontalAlignment="Stretch"/>

        <!-- 詳細列表 -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DataGrid x:Name="SlowGrid"
                      Background="White" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      RowBackground="White" AlternatingRowBackground="#FAFBFC"
                      BorderThickness="0" FontFamily="Consolas" FontSize="12"
                      CanUserResizeRows="False"
                      SelectionChanged="SlowGrid_SelectionChanged">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader"
                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                        <Setter Property="Background"  Value="{StaticResource SecondaryBrush}"/>
                        <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="FontWeight"  Value="SemiBold"/>
                        <Setter Property="Padding"     Value="8,6"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{DynamicResource S.k935edb}" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SeverityIcon}"
                                           HorizontalAlignment="Center" FontSize="14"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource S.k7cd2c3}"  Binding="{Binding AvgTimeLabel}"  Width="90"/>
                    <DataGridTextColumn Header="{DynamicResource S.k2b51ff}"  Binding="{Binding MaxTimeLabel}"  Width="90"/>
                    <DataGridTextColumn Header="{DynamicResource S.kaa5f82}"    Binding="{Binding SumTimeLabel}"  Width="90"/>
                    <DataGridTextColumn Header="{DynamicResource S.k21773a}"  Binding="{Binding ExecCount}"     Width="80"/>
                    <DataGridTextColumn Header="{DynamicResource S.k02590f}" Binding="{Binding NoIndexCount}" Width="90"/>
                    <DataGridTextColumn Header="{DynamicResource S.k2801a2}"    Binding="{Binding Schema}"        Width="110"/>
                    <DataGridTextColumn Header="{DynamicResource S.SQL932c68}"  Binding="{Binding SqlPreview}"    Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- SQL 全文 -->
            <Border Grid.Row="1" Background="#F4F6F9"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    MaxHeight="110" Padding="12,8"
                    Visibility="{Binding ElementName=SqlDetail, Path=Text,
                                 Converter={StaticResource NullOrEmptyToVisibility},
                                 FallbackValue=Collapsed}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="SqlDetail" FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,0,0,0">
                        <Button Content="{DynamicResource S.k2e43a2}" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,5" Margin="0,0,0,4" Click="CopySql_Click"/>
                        <Button Content="⚡ EXPLAIN" Style="{StaticResource PrimaryButtonStyle}"
                                Padding="8,5" Click="Explain_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部 -->
        <Border Grid.Row="4" Background="{StaticResource StatusBarGradientBrush}" Padding="12,6">
            <TextBlock x:Name="SummaryText" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>
