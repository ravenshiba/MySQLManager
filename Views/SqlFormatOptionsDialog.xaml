<Window x:Class="MySQLManager.Views.SqlFormatOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.SQLae3bd4}" Height="340" Width="400"
        MinWidth="360" MinHeight="300"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
    </Window.Resources>
    <StackPanel Margin="24">
        <TextBlock Text="{DynamicResource S.SQLef8dfe}" FontSize="14" FontWeight="Bold"
                   Foreground="#37474F" Margin="0,0,0,20"/>

        <CheckBox x:Name="UpperCaseChk" Content="{DynamicResource S.SELECTFR76d209}"
                  FontSize="12" Margin="0,0,0,12" IsChecked="True"/>

        <CheckBox x:Name="NewlineAndChk" Content="{DynamicResource S.ANDORd8c621}"
                  FontSize="12" Margin="0,0,0,12" IsChecked="True"/>

        <CheckBox x:Name="CompactJoinsChk" Content="{DynamicResource S.JOINfd4aa5}"
                  FontSize="12" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
            <TextBlock Text="{DynamicResource S.k0247f1}" VerticalAlignment="Center"
                       FontSize="12" Foreground="#607D8B" Margin="0,0,10,0"/>
            <ComboBox x:Name="IndentCombo" Width="80" Height="30">
                <ComboBoxItem Content="2" Tag="2"/>
                <ComboBoxItem Content="4" Tag="4" IsSelected="True"/>
                <ComboBoxItem Content="8" Tag="8"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource S.k625fb2}" Width="80" Height="32" Click="Cancel_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.ke9dabe}" Width="80" Height="32" Click="Save_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="{StaticResource AccentBrush}"/>
        </StackPanel>
    </StackPanel>
</Window>
