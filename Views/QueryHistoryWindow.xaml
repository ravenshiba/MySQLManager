<Window x:Class="MySQLManager.Views.QueryHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.ke3ef07}" Height="600" Width="840"
        MinWidth="640" MinHeight="460"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <Border Grid.Row="0" Background="{StaticResource DeepBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                Padding="14,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ComboBox x:Name="SortCombo" Width="110" Height="28"
                              SelectionChanged="SortCombo_Changed" FontSize="11">
                        <ComboBoxItem Content="{DynamicResource S.k411f73}" IsSelected="True"/>
                        <ComboBoxItem Content="{DynamicResource S.k5f2b40}"/>
                        <ComboBoxItem Content="{DynamicResource S.k5fe6f2}"/>
                    </ComboBox>
                    <Button Content="{DynamicResource S.k7a41a9}" Click="ClearAll_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="28" Padding="10,0" Margin="8,0,0,0" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍" VerticalAlignment="Center"
                               FontSize="13" Margin="0,0,8,0"/>
                    <TextBox x:Name="SearchBox" Width="280" Height="28"
                             FontSize="12" Padding="8,0"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock x:Name="CountLabel" VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="12,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主體 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側清單 -->
            <ListBox Grid.Column="0" x:Name="HistoryList"
                     BorderThickness="0,0,1,0"
                     BorderBrush="{StaticResource BorderBrush}"
                     SelectionChanged="HistoryList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                       FontSize="11" VerticalAlignment="Top"
                                       Margin="0,1,8,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ShortSql}" FontSize="11"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding DisplayTime}" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text=" | " FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding ExecInfo}" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text=" | " FontSize="9"
                                               Foreground="#9E9E9E"
                                               Visibility="{Binding Tags, Converter={StaticResource NullToVisibility}}"/>
                                    <TextBlock Text="{Binding Tags}" FontSize="9"
                                               Foreground="#7E57C2"
                                               Visibility="{Binding Tags, Converter={StaticResource NullToVisibility}}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding FavStar}"
                                       FontSize="14" Foreground="#FFC107"
                                       VerticalAlignment="Center" Margin="4,0,0,0"
                                       Cursor="Hand" MouseLeftButtonDown="Star_Click"
                                       ToolTip="{DynamicResource S.k44c2a1}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- 右側詳情 -->
            <Grid Grid.Column="1">
                <TextBlock Text="{DynamicResource S.k4cae00}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           x:Name="EmptyHint"/>
                <Grid x:Name="DetailPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 詳情標頭 -->
                    <Border Grid.Row="0" Padding="16,10"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource DeepBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="DetailTime" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text=" | DB: " FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="DetailDb" FontSize="11"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text=" | " FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="DetailInfo" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Text="{DynamicResource S.kf7d603}" VerticalAlignment="Center"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button DockPanel.Dock="Right" Content="{DynamicResource S.k5db8e1}"
                                        Click="SaveTag_Click" Height="24"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,0" FontSize="10"/>
                                <TextBox x:Name="TagBox" Height="24" FontSize="11"
                                         Padding="6,0" VerticalContentAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- SQL 預覽 -->
                    <TextBox Grid.Row="1" x:Name="SqlPreview"
                             IsReadOnly="True" FontFamily="Consolas, Courier New"
                             FontSize="12" Padding="16"
                             Background="#FAFAFA"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>

                    <!-- 操作按鈕 -->
                    <Border Grid.Row="2" Padding="14,10"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource DeepBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource S.ke75f80}" Click="OpenInEditor_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="{StaticResource AccentBrush}"
                                    Padding="14,7" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource S.k9f9e90}" Click="RunQuery_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#34A853"
                                    Padding="14,7" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource S.SQL36a961}" Click="CopySql_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="14,7"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- 鍵盤提示 -->
        <Border Grid.Row="2" Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource DeepBrush}">
            <TextBlock Text="{DynamicResource S.EnterCtr9f4822}"
                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Window>
