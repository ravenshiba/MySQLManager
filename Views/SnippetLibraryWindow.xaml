<Window x:Class="MySQLManager.Views.SnippetLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.SQL74aca8}" Height="580" Width="860"
        MinWidth="640" MinHeight="440"
        Background="#F0F2F5"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 左側：分類 + 清單 ══ -->
        <Grid Grid.Column="0" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 標題 -->
            <Border Grid.Row="0" Background="{StaticResource DeepBrush}"
                    Padding="14,12" BorderThickness="0,0,1,1"
                    BorderBrush="{StaticResource BorderBrush}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource S.SQL40a9a2}" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="TotalLabel" FontSize="11" Margin="0,2,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- 搜尋 -->
            <Border Grid.Row="1" Padding="10,8"
                    BorderThickness="0,0,1,1" BorderBrush="{StaticResource BorderBrush}">
                <TextBox x:Name="SearchBox" Padding="8,6"
                         FontSize="12" BorderBrush="{StaticResource BorderBrush}"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Tag" Value="🔍 搜尋標題、SQL、標籤…"/>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>

            <!-- 片段清單 -->
            <ListBox Grid.Row="2" x:Name="SnippetList"
                     BorderThickness="0,0,1,0"
                     BorderBrush="{StaticResource BorderBrush}"
                     SelectionChanged="SnippetList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,4">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                       FontSize="12" TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Preview}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                       Margin="0,2,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Border Background="#E3F2FD" CornerRadius="3" Padding="5,1"
                                        Margin="0,0,4,0">
                                    <TextBlock Text="{Binding Category}" FontSize="9"
                                               Foreground="#1565C0"/>
                                </Border>
                                <TextBlock Text="{Binding UseCount, StringFormat='▶ {0}'}"
                                           FontSize="9"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- 新增按鈕 -->
            <Button Grid.Row="3" Content="{DynamicResource S.k8aff27}" Click="AddSnippet_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="{StaticResource AccentBrush}"
                    Margin="10" Padding="0,10"/>
        </Grid>

        <!-- ══ 右側：編輯 / 預覽 ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 空白提示 -->
            <StackPanel x:Name="EmptyPanel"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Grid.Row="0" Grid.RowSpan="4">
                <TextBlock Text="📚" FontSize="52" HorizontalAlignment="Center"
                           Foreground="#DADCE0"/>
                <TextBlock Text="{DynamicResource S.k3e3bc3}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="{DynamicResource S.SQLcf397a}" FontSize="12"
                           Foreground="#BDBDBD"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 編輯區 -->
            <Border x:Name="EditPanel" Visibility="Collapsed"
                    Grid.Row="0" Grid.RowSpan="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 欄位列 -->
                    <Grid Grid.Row="0" Margin="16,14,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="{DynamicResource S.k1ae323}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TitleBox" Padding="8,6" FontSize="13"
                                     BorderBrush="{StaticResource BorderBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="{DynamicResource S.ke74004}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CategoryBox" IsEditable="True"
                                      Padding="8,5" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource S.k0f4356}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TagsBox" Padding="8,6" FontSize="13"
                                     BorderBrush="{StaticResource BorderBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- SQL 編輯區 -->
                    <Border Grid.Row="2" Margin="16,10,16,0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4">
                        <TextBox x:Name="SqlBox"
                                 FontFamily="Consolas" FontSize="13"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="#FAFBFC"
                                 Padding="12"/>
                    </Border>

                    <!-- 操作按鈕列 -->
                    <Border Grid.Row="3" Padding="16,10"
                            BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource DeepBrush}">
                        <DockPanel>
                            <!-- 危險按鈕靠左 -->
                            <Button DockPanel.Dock="Left" Content="{DynamicResource S.kfba47c}"
                                    Click="DeleteSnippet_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#D93025" Padding="12,7"/>

                            <!-- 主要按鈕靠右 -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="{DynamicResource S.kd5f28a}" Click="SaveSnippet_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="{StaticResource AccentBrush}"
                                        Padding="16,7" Margin="0,0,8,0"/>
                                <Button Content="{DynamicResource S.kcc9e55}" Click="InsertSnippet_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#1E8E3E" Padding="16,7"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
