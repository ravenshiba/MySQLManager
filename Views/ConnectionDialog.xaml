<Window x:Class="MySQLManager.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MySQLManager.ViewModels"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.k456374}" Height="600" Width="860"
        MinWidth="760" MinHeight="520"
        Background="#F7F8FA"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <vm:ConnectionDialogViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
            <!-- 表單 Label 樣式 -->
            <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                <Setter Property="FontSize"   Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,0,0,4"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════
             左側：連線清單
        ═══════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 標題 -->
                <Border Grid.Row="0" Padding="14,14,14,10"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Height="14" CornerRadius="2"
                                Background="{StaticResource AccentGradientBrush}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource S.k979fe1}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 連線清單 -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Profiles}"
                         Background="Transparent" BorderThickness="0"
                         Padding="6,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <Ellipse Width="7" Height="7"
                                                     VerticalAlignment="Center" Margin="0,0,7,0">
                                                <Ellipse.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#1976D2" Offset="0"/>
                                                        <GradientStop Color="#7C4DFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="14,0,0,0">
                                            <Run Text="{Binding Username}"/>
                                            <Run Text="@"/>
                                            <Run Text="{Binding Host}"/>
                                            <Run Text=":"/>
                                            <Run Text="{Binding Port}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Group}"
                                                   FontSize="9" Margin="14,1,0,0"
                                                   Foreground="#9E9E9E"/>
                                    </StackPanel>
                                    <!-- 最愛星號 -->
                                    <TextBlock Grid.Column="1" Text="★"
                                               FontSize="14" VerticalAlignment="Center"
                                               Foreground="#FFC107" Margin="4,0,0,0"
                                               Visibility="{Binding IsFavorite,
                                                   Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin"  Value="0,1"/>
                            <Setter Property="Cursor"  Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root" CornerRadius="6"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background"
                                                        Value="{StaticResource HoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background"
                                                        Value="#D2E3FC"/>
                                                <Setter TargetName="Root" Property="BorderBrush"
                                                        Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="Root" Property="BorderThickness"
                                                        Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <EventSetter Event="MouseLeftButtonDown" Handler="ProfileItem_Click"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- 底部按鈕 -->
                <Border Grid.Row="2" Padding="8,8"
                        BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding NewProfileCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="{StaticResource AccentBrush}"
                                Foreground="#F0F2F5"
                                Padding="10,5" Margin="0,0,6,0" FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource S.k66ab5e}"/>
                            </StackPanel>
                        </Button>
                        <Button Background="#FEECEC"
                                Foreground="{StaticResource ErrorBrush}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="10,5" FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource S.k0c06d4}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════
             右側：設定表單
        ═══════════════════════════════ -->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 右側標題 -->
            <Border Grid.Row="0" Padding="24,16,24,14"
                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource S.k495d5b}"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Border CornerRadius="4" Padding="8,2" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E3F2FD" Offset="0"/>
                                <GradientStop Color="#E3F2FD" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="MySQL" FontSize="10"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 表單 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="24,16,24,0">
                <StackPanel>

                    <!-- 連線名稱 -->
                    <TextBlock Text="{DynamicResource S.kcdfd4b}" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding EditingProfile.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <!-- 主機 + 埠號 (卡片) -->
                    <TextBlock Text="{DynamicResource S.k0ac807}" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EditingProfile.Host, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding EditingProfile.Port, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" TextAlignment="Center"/>
                    </Grid>

                    <!-- 帳號 / 密碼 (並排) -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource S.kebd16e}" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding EditingProfile.Username, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource S.k6662c8}" Style="{StaticResource FieldLabelStyle}"/>
                            <PasswordBox x:Name="PasswordInput"
                                         PasswordChanged="PasswordInput_Changed"/>
                        </StackPanel>
                    </Grid>

                    <!-- 預設資料庫 -->
                    <TextBlock Text="{DynamicResource S.k02de43}" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding EditingProfile.DefaultDatabase, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <!-- 選項 CheckBox -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="{StaticResource SecondaryBrush}" CornerRadius="4"
                                Padding="12,6" Margin="0,0,8,0">
                            <StackPanel>
                                <CheckBox Content="{DynamicResource S.SSLf6b26a}"
                                          IsChecked="{Binding EditingProfile.UseSsl}"
                                          FontSize="12"/>
                                <CheckBox Content="{DynamicResource S.VerifyCAf8d165}"
                                          IsChecked="{Binding EditingProfile.SslVerifyServer}"
                                          Margin="0,6,0,0" FontSize="12"
                                          IsEnabled="{Binding EditingProfile.UseSsl}"/>
                                <TextBlock Text="{DynamicResource S.CA5fdfc2}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding EditingProfile.SslCaCert}"
                                             FontSize="12" Padding="6,4"
                                             IsEnabled="{Binding EditingProfile.UseSsl}"/>
                                    <Button Grid.Column="1" Content="..." Margin="4,0,0,0"
                                            Padding="8,4" FontSize="11"
                                            IsEnabled="{Binding EditingProfile.UseSsl}"
                                            Click="BrowseCaCert_Click"/>
                                </Grid>
                                <TextBlock Text="{DynamicResource S.pemcrta7f579}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding EditingProfile.SslClientCert}"
                                             FontSize="12" Padding="6,4"
                                             IsEnabled="{Binding EditingProfile.UseSsl}"/>
                                    <Button Grid.Column="1" Content="..." Margin="4,0,0,0"
                                            Padding="8,4" FontSize="11"
                                            IsEnabled="{Binding EditingProfile.UseSsl}"
                                            Click="BrowseClientCert_Click"/>
                                </Grid>
                                <TextBlock Text="{DynamicResource S.keyc1beec}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding EditingProfile.SslClientKey}"
                                             FontSize="12" Padding="6,4"
                                             IsEnabled="{Binding EditingProfile.UseSsl}"/>
                                    <Button Grid.Column="1" Content="..." Margin="4,0,0,0"
                                            Padding="8,4" FontSize="11"
                                            IsEnabled="{Binding EditingProfile.UseSsl}"
                                            Click="BrowseClientKey_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource SecondaryBrush}" CornerRadius="4"
                                Padding="12,6">
                            <CheckBox Content="{DynamicResource S.kda5e34}"
                                      IsChecked="{Binding EditingProfile.SavePassword}"
                                      FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <!-- 群組 / 最愛 / 備註 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource S.k65eb2f}" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding EditingProfile.Group, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="8,0" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource S.k3607db}" Style="{StaticResource FieldLabelStyle}"/>
                            <CheckBox Content="{DynamicResource S.k0b9b02}" FontSize="12" Margin="0,6,0,0"
                                      IsChecked="{Binding EditingProfile.IsFavorite}"
                                      Foreground="#E65100"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="{DynamicResource S.k0fb49f}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditingProfile.Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="56" Padding="8,6" FontSize="12"
                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- SSH Tunnel 區塊 -->
                    <Border CornerRadius="8" Padding="0" Margin="0,0,0,16"
                            BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#D2E3FC" Offset="0"/>
                                <GradientStop Color="#EDE7F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FAFBFC" Offset="0"/>
                                <GradientStop Color="#F3F0FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel>
                            <!-- SSH 標題列 -->
                            <Border Padding="14,10" CornerRadius="8,8,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#EEF4FF" Offset="0"/>
                                        <GradientStop Color="#F3F0FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding EditingProfile.UseSshTunnel}"
                                              Margin="0,0,10,0"/>
                                    <TextBlock Text="🔐" FontSize="13" Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="SSH Tunnel"
                                               FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource S.ke4b5c9}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- SSH 設定內容 (展開) -->
                            <Border Padding="14,12"
                                    Visibility="{Binding EditingProfile.UseSshTunnel,
                                                 Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{DynamicResource S.SSHaa4987}" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditingProfile.SshHost, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Port" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditingProfile.SshPort, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{DynamicResource S.SSHd5f5ff}" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding EditingProfile.SshUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,10"/>

                                    <!-- 認證方式 -->
                                    <TextBlock Text="{DynamicResource S.k55ef10}" Style="{StaticResource FieldLabelStyle}"/>
                                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="4"
                                            Padding="10,6" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="{DynamicResource S.k32afb4}"
                                                         IsChecked="{Binding EditingProfile.SshUseKeyAuth, Converter={StaticResource InverseBool}}"
                                                         Margin="0,0,20,0" FontSize="12"/>
                                            <RadioButton Content="{DynamicResource S.kc2ae2c}"
                                                         IsChecked="{Binding EditingProfile.SshUseKeyAuth}"
                                                         FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{DynamicResource S.SSHcfb76a}" Style="{StaticResource FieldLabelStyle}"/>
                                            <PasswordBox x:Name="SshPasswordBox"
                                                         PasswordChanged="SshPasswordBox_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{DynamicResource S.pemppk7ee0c2}" Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding EditingProfile.SshKeyPath, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="Consolas" FontSize="11"/>
                                                <Button Grid.Column="1" Content="📂"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Background="{StaticResource SecondaryBrush}"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        Padding="8,5" Margin="4,0,0,0"
                                                        Click="BrowseSshKey_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 測試結果 -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,4"
                            Visibility="{Binding TestResult, Converter={StaticResource NullOrEmptyToVisibility}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E6F4EA"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TestSuccess}" Value="False">
                                        <Setter Property="Background" Value="#FEECEC"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✅"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TestSuccess}" Value="False">
                                                <Setter Property="Text" Value="❌"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding TestResult}" Foreground="White" FontSize="12"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部操作列 -->
            <Border Grid.Row="2" Padding="24,12"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Button HorizontalAlignment="Left"
                            Command="{Binding TestConnectionCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="{StaticResource SecondaryBrush}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Padding="14,7">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource S.k7faef4}"/>
                        </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Click="CancelButton_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="{StaticResource SecondaryBrush}"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Padding="14,7" Margin="0,0,8,0"
                                Content="{DynamicResource S.k625fb2}"/>
                        <Button Command="{Binding ConnectCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="18,7">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1976D2" Offset="0"/>
                                    <GradientStop Color="#1565C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" Margin="0,0,7,0"/>
                                <TextBlock Text="{DynamicResource S.kb2e9aa}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
