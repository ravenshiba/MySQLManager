<Window x:Class="MySQLManager.Views.RoutineEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.StoredPr9047ae}"
        Height="680" Width="1020"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─ 左側：Routine 清單 ─ -->
        <Border Grid.Column="0" Background="#FFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 標題 + DB 選擇 -->
                <Border Grid.Row="0" Background="#F0F2F5" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="Routines" Foreground="#1976D2"
                                   FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Databases}"
                                  SelectedItem="{Binding SelectedDatabase}"
                                  Background="#E8ECF0" Foreground="White"
                                  BorderBrush="#9E9E9E" Padding="6,4"
                                  FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- 篩選 -->
                <Border Grid.Row="1" Background="#EEF4FF" Padding="8,5">
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#F0F2F5" Foreground="White"
                             BorderBrush="#9E9E9E" Padding="6,4" FontSize="11"
                             Tag="搜尋 Routine…"/>
                </Border>

                <!-- 清單 -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredRoutines}"
                         SelectedItem="{Binding SelectedRoutine, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         FontFamily="Consolas" FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,2">
                                <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="White"/>
                                    <TextBlock Text="{Binding Type}" Foreground="#9E9E9E" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"    Value="8,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F0F2F5"/>
                                </Trigger>
                                <Trigger Property="IsSelected"   Value="True">
                                    <Setter Property="Background" Value="#D2E3FC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- 底部按鈕 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            Background="#F0F2F5" HorizontalAlignment="Stretch">
                    <Button Content="＋ SP" Click="NewProcedure_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#1E8E3E" Margin="4,4,2,4"
                            ToolTip="{DynamicResource S.StoredPr33d7fc}"/>
                    <Button Content="＋ FN" Click="NewFunction_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#1565C0" Margin="2,4,2,4"
                            ToolTip="{DynamicResource S.Functionba4a60}"/>
                    <Button Content="🗑" Click="DeleteRoutine_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#D93025" Margin="2,4,4,4"
                            ToolTip="{DynamicResource S.Routine8056ef}"/>
                </StackPanel>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="4"
                      Background="#F0F2F5" HorizontalAlignment="Stretch"/>

        <!-- ─ 右側：編輯器 ─ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 工具列 -->
                <RowDefinition Height="*"/>     <!-- 編輯器 -->
                <RowDefinition Height="Auto"/>  <!-- 結果/狀態 -->
            </Grid.RowDefinitions>

            <!-- 工具列 -->
            <Border Grid.Row="0" Background="#F0F2F5" Padding="8,6">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{DynamicResource S.F5b0b266}" Click="Execute_Click"
                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,4,0"/>
                        <Button Content="{DynamicResource S.CtrlSd17b4c}" Click="Save_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="#1565C0" Margin="0,0,4,0"/>
                        <Button Content="{DynamicResource S.kb401bd}" Click="Refresh_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="#9E9E9E" Margin="0,0,12,0"/>
                        <Separator Width="1" Background="#9E9E9E" Margin="0,2,12,2"/>
                        <TextBlock Text="{Binding CurrentTitle}"
                                   Foreground="#1976D2" FontWeight="SemiBold"
                                   VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- 修改提示 -->
                        <Border Background="#E65100" CornerRadius="3" Padding="8,3"
                                Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{DynamicResource S.k9189b0}" Foreground="White" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- AvalonEdit 編輯器 -->
            <Border Grid.Row="1" BorderBrush="#F0F2F5" BorderThickness="0,1,0,0">
                <avalon:TextEditor x:Name="CodeEditor"
                                   FontFamily="Consolas, Courier New"
                                   FontSize="13"
                                   Background="#F4F6F9"
                                   Foreground="#37474F"
                                   ShowLineNumbers="True"
                                   WordWrap="False"/>
            </Border>

            <!-- 執行結果 / 狀態列 -->
            <Border Grid.Row="2" Padding="10,6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#F0F2F5"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Background" Value="#7F1A1A"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Consolas" FontSize="12"
                           TextWrapping="NoWrap"/>
            </Border>
        </Grid>
    </Grid>
</Window>
