<Window x:Class="MySQLManager.Views.TableStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.k31e0da}" Width="960"
        MinWidth="720" MinHeight="460" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5"
        FontFamily="Segoe UI, Microsoft JhengHei">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 工具列 -->
            <RowDefinition Height="160"/>   <!-- 摘要卡片 -->
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>     <!-- 表格 -->
            <RowDefinition Height="Auto"/>  <!-- 狀態列 -->
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource S.k4a4f21}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <ComboBox x:Name="DbCombo" Width="180" Margin="4,0,12,0"
                              SelectionChanged="DbCombo_Changed"/>
                    <Button Content="{DynamicResource S.kb401bd}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Refresh_Click" Padding="12,6"/>
                    <Button Content="{DynamicResource S.CSVebe99a}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="8,0,0,0" Padding="10,6"
                            Click="Export_Click"/>
                </StackPanel>
                <TextBox x:Name="SearchBox"
                         HorizontalAlignment="Right" Width="220"
                         Padding="8,6" FontSize="12"
                         Text="" TextChanged="Search_Changed"
                         ToolTip="{DynamicResource S.k9550b5}"/>
            </Grid>
        </Border>

        <!-- 摘要卡片列 -->
        <Border Grid.Row="1" Background="{StaticResource SecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Margin="12,12" x:Name="SummaryCards"/>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Row="2" Height="5" Background="{StaticResource SecondaryBrush}"
                      HorizontalAlignment="Stretch"/>

        <!-- 詳細列表 -->
        <DataGrid Grid.Row="3" x:Name="StatsGrid"
                  Background="White" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  RowBackground="White" AlternatingRowBackground="#FAFBFC"
                  BorderThickness="0" FontFamily="Consolas" FontSize="12"
                  CanUserResizeRows="False" CanUserSortColumns="True">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader"
                       BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                    <Setter Property="Background"  Value="{StaticResource SecondaryBrush}"/>
                    <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                    <Setter Property="Padding"     Value="8,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EEF4FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#D2E3FC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource S.k7b5e7c}"    Binding="{Binding TableName}"   Width="*"   SortMemberPath="TableName"/>
                <DataGridTextColumn Header="ENGINE"    Binding="{Binding Engine}"      Width="70"  SortMemberPath="Engine"/>
                <DataGridTextColumn Header="{DynamicResource S.k43b525}"  Binding="{Binding RowCountLabel}" Width="90" SortMemberPath="RowCount"/>
                <DataGridTextColumn Header="{DynamicResource S.k74e256}"  Binding="{Binding DataMbLabel}"  Width="90" SortMemberPath="DataMb"/>
                <DataGridTextColumn Header="{DynamicResource S.ke13471}"  Binding="{Binding IndexMbLabel}" Width="90" SortMemberPath="IndexMb"/>
                <DataGridTemplateColumn Header="{DynamicResource S.k189141}" Width="160" SortMemberPath="TotalMb">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding TotalMbLabel}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Border Grid.Column="1" Height="10" CornerRadius="3"
                                        Background="#E8F0FE" VerticalAlignment="Center">
                                    <Border Height="10" CornerRadius="3" HorizontalAlignment="Left"
                                            Width="{Binding SizeBarWidth}"
                                            Background="{Binding SizeBarColor}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource S.kb1db85}"  Binding="{Binding UpdateLabel}"  Width="110" SortMemberPath="UpdateTime"/>
                <DataGridTextColumn Header="{DynamicResource S.k0c611a}"  Binding="{Binding CreateLabel}"  Width="90"  SortMemberPath="CreateTime"/>
                <DataGridTextColumn Header="Collation" Binding="{Binding Collation}"    Width="120" SortMemberPath="Collation"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="{StaticResource StatusBarGradientBrush}" Padding="12,6">
            <TextBlock x:Name="StatusBar" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>
