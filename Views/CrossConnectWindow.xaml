<Window x:Class="MySQLManager.Views.CrossConnectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="{DynamicResource S.k775303}" Height="700" Width="1200"
        MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource S.A4af55f}" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <ComboBox x:Name="ConnACombo" Width="200" FontSize="12" Padding="6,4" Margin="0,0,12,0"/>
                <TextBlock Text="{DynamicResource S.B2fe332}" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <ComboBox x:Name="ConnBCombo" Width="200" FontSize="12" Padding="6,4" Margin="0,0,16,0"/>
                <Button Content="{DynamicResource S.k99bba1}" Click="RunBoth_Click"
                        Style="{StaticResource PrimaryButtonStyle}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource S.k91cd21}" Click="DiffResults_Click"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="10,4"/>
                <TextBlock x:Name="StatusLabel" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- SQL Editor -->
        <avalon:TextEditor Grid.Row="1" x:Name="SqlEditor"
                           FontFamily="Consolas" FontSize="13"
                           ShowLineNumbers="True"
                           SyntaxHighlighting="SQL"
                           Padding="8"/>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- Results side by side -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Result A -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#E3F2FD" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource S.A0d93c1}" FontWeight="Medium" FontSize="12"
                                   Foreground="#1565C0"/>
                        <TextBlock x:Name="CountA" FontSize="11" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <DataGrid Grid.Row="1" x:Name="GridA"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          FontSize="12" FontFamily="Consolas"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"/>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Result B -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#E8F5E9" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource S.B0a9701}" FontWeight="Medium" FontSize="12"
                                   Foreground="#2E7D32"/>
                        <TextBlock x:Name="CountB" FontSize="11" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <DataGrid Grid.Row="1" x:Name="GridB"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          FontSize="12" FontFamily="Consolas"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"/>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="4" x:Name="FooterLabel"
                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                   Padding="10,4" Background="{StaticResource SecondaryBrush}"/>
    </Grid>
</Window>
