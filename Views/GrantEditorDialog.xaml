<Window x:Class="MySQLManager.Views.GrantEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.kb9e7d8}" Height="480" Width="500"
        MinWidth="420" MinHeight="380"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#F0F2F5" Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleBlock" FontSize="14" FontWeight="Bold"
                   Foreground="#37474F" Margin="0,0,0,14"/>

        <Border Grid.Row="1" Background="#E8F0FE" CornerRadius="6" Padding="12,8" Margin="0,0,0,14">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="{DynamicResource S.kd2692f}" Click="SelectAll_Click"
                        Width="50" Height="24" FontSize="10"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button DockPanel.Dock="Right" Content="{DynamicResource S.k92fb20}" Click="ClearAll_Click"
                        Width="55" Height="24" FontSize="10" Margin="0,0,6,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <TextBlock Text="{DynamicResource S.kf09d63}" VerticalAlignment="Center"
                           FontSize="11" Foreground="#3C4043"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PrivList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}"
                                  Margin="4,5" FontSize="12"
                                  Foreground="#37474F"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{DynamicResource S.k625fb2}" Width="80" Height="32" Click="Cancel_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.GRANTb333af}" Width="110" Height="32" Click="Grant_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="{StaticResource AccentBrush}"/>
        </StackPanel>
    </Grid>
</Window>
