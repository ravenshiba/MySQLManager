<Window x:Class="MySQLManager.Views.ShortcutHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.k5d0ae5}" Height="560" Width="600"
        MinHeight="400" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" x:Name="SearchBox" Margin="0,0,0,12"
                 FontSize="13" Padding="8,6"
                 TextChanged="Search_Changed"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="GroupPanel"/>
        </ScrollViewer>

        <Button Grid.Row="2" Content="{DynamicResource S.kb04c17}" IsDefault="True" IsCancel="True"
                Style="{StaticResource SecondaryButtonStyle}"
                HorizontalAlignment="Right" Padding="24,6" Margin="0,12,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
