<Window x:Class="MySQLManager.Views.BlobPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.BLOBe37136}"
        Height="520" Width="680"
        MinHeight="360" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="{DynamicResource S.k448da1}" Click="SaveAs_Click"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.Hex4dc226}" Click="CopyHex_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.Base64d6dba7}" Click="CopyBase64_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,16,0"/>
            <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="0,2"/>
            <TextBlock x:Name="InfoLabel" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Preview area -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{StaticResource SecondaryBrush}">
            <Grid>
                <!-- Image preview -->
                <ScrollViewer x:Name="ImageScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform" MaxWidth="900" MaxHeight="600"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="8"/>
                </ScrollViewer>

                <!-- Text/Hex preview -->
                <TextBox x:Name="HexBox"
                         IsReadOnly="True"
                         FontFamily="Consolas" FontSize="11"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderThickness="0" Padding="10"
                         Visibility="Collapsed"/>

                <!-- Not renderable placeholder -->
                <StackPanel x:Name="BinaryPlaceholder"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"
                               Opacity="0.3"/>
                    <TextBlock x:Name="BlobSizeLabel" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- View mode tabs + status -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <RadioButton x:Name="ImageModeBtn" Content="{DynamicResource S.kf79f66}" IsChecked="True"
                             Margin="0,0,12,0" VerticalAlignment="Center"
                             Checked="Mode_Changed"/>
                <RadioButton x:Name="HexModeBtn" Content="🔢 Hex dump"
                             Margin="0,0,12,0" VerticalAlignment="Center"
                             Checked="Mode_Changed"/>
                <RadioButton x:Name="TextModeBtn" Content="{DynamicResource S.kc02711}"
                             VerticalAlignment="Center" Checked="Mode_Changed"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{DynamicResource S.kb04c17}" IsDefault="True"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="20,6" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
