<Window x:Class="MySQLManager.Views.DataDiffWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.kb994f1}" Height="680" Width="1100"
        MinWidth="800" MinHeight="520"
        Background="#F0F2F5"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 選擇列 -->
            <RowDefinition Height="Auto"/>  <!-- 篩選/統計列 -->
            <RowDefinition Height="*"/>     <!-- 主體 -->
            <RowDefinition Height="Auto"/>  <!-- 狀態列 -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0：選擇資料表 ══ -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左表 -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource S.k044d71}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Databases}"
                                  SelectedItem="{Binding LeftDatabase}"
                                  Padding="8,6" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="." VerticalAlignment="Bottom"
                                   FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="2,0"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding LeftTables}"
                                  SelectedItem="{Binding LeftTable}"
                                  Padding="8,6" FontSize="13"/>
                    </Grid>
                </StackPanel>

                <!-- VS 分隔 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom"
                            HorizontalAlignment="Center" Margin="20,0">
                    <Border Background="#E3F2FD" CornerRadius="20"
                            Padding="14,6" Margin="0,0,0,2">
                        <TextBlock Text="VS" FontSize="15" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                    </Border>
                </StackPanel>

                <!-- 右表 -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource S.k5daf15}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Databases}"
                                  SelectedItem="{Binding RightDatabase}"
                                  Padding="8,6" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="." VerticalAlignment="Bottom"
                                   FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="2,0"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding RightTables}"
                                  SelectedItem="{Binding RightTable}"
                                  Padding="8,6" FontSize="13"/>
                    </Grid>
                </StackPanel>

                <!-- 比對按鈕 -->
                <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="16,0,0,0">
                    <Button Command="{Binding CompareCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#1565C0" Padding="20,8" FontSize="13" FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource S.kf5d1bd}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Row 1：統計 + 進階選項 ══ -->
        <Grid Grid.Row="1" Background="#FAFBFC">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 統計徽章 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="16,10">

                <!-- 新增 -->
                <Border Background="#E8F5E9" CornerRadius="6" Padding="12,6" Margin="0,0,8,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" Foreground="#2E7D32" FontWeight="Bold" Margin="0,0,4,0"/>
                        <TextBlock Foreground="#2E7D32" FontWeight="SemiBold">
                            <Run Text="{Binding AddedCount}"/>
                            <Run Text="{DynamicResource S.ke4f385}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 刪除 -->
                <Border Background="#FEECEC" CornerRadius="6" Padding="12,6" Margin="0,0,8,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="－" Foreground="#C62828" FontWeight="Bold" Margin="0,0,4,0"/>
                        <TextBlock Foreground="#C62828" FontWeight="SemiBold">
                            <Run Text="{Binding DeletedCount}"/>
                            <Run Text="{DynamicResource S.ked6e8d}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 修改 -->
                <Border Background="#FFF8E1" CornerRadius="6" Padding="12,6" Margin="0,0,8,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✎" Foreground="#E65100" FontWeight="Bold" Margin="0,0,4,0"/>
                        <TextBlock Foreground="#E65100" FontWeight="SemiBold">
                            <Run Text="{Binding ModifiedCount}"/>
                            <Run Text="{DynamicResource S.k5d7ab7}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 相同 -->
                <Border Background="#F3F4F6" CornerRadius="6" Padding="12,6"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Foreground="#78909C">
                        <Run Text="{Binding UnchangedCount}"/>
                        <Run Text="{DynamicResource S.k06137a}"/>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- 右側工具列 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,16,0">

                <!-- 進階選項 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="{DynamicResource S.k4417d3}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding KeyColumn, UpdateSourceTrigger=PropertyChanged}"
                             Width="100" Height="28" FontSize="12" Padding="6,4"
                             ToolTip="{DynamicResource S.idf6fc54}"
                             BorderBrush="{StaticResource BorderBrush}"/>
                    <TextBlock Text="WHERE" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,6,0"/>
                    <TextBox Text="{Binding WhereClause, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" Height="28" FontSize="12" Padding="6,4"
                             ToolTip="{DynamicResource S.WHEREcre5feac7}"
                             BorderBrush="{StaticResource BorderBrush}"/>
                </StackPanel>

                <!-- 顯示相同 Toggle -->
                <Border Background="#F3F4F6" CornerRadius="6" Padding="10,6" Margin="0,0,8,0"
                        Cursor="Hand" MouseLeftButtonDown="ToggleUnchanged_Click">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding ShowUnchanged}" VerticalAlignment="Center"
                                  Margin="0,0,6,0" IsHitTestVisible="False"/>
                        <TextBlock Text="{DynamicResource S.kf019ab}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- 複製 SQL -->
                <Button Command="{Binding CopyPatchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,6" Margin="0,0,6,0"
                        ToolTip="{DynamicResource S.SQL9943f9}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" Margin="0,0,4,0" FontSize="11"/>
                        <TextBlock Text="{DynamicResource S.SQL950c4f}" FontSize="12"/>
                    </StackPanel>
                </Button>

                <!-- 匯出 SQL -->
                <Button Command="{Binding ExportSqlCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,6"
                        ToolTip="{DynamicResource S.SQL7ee179}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,4,0" FontSize="11"/>
                        <TextBlock Text="{DynamicResource S.sqlcdc0e8}" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ Row 2：比對結果 ══ -->
        <Grid Grid.Row="2">
            <!-- 空白提示 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasResult, Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="⚖" FontSize="52" HorizontalAlignment="Center"
                           Foreground="#DADCE0"/>
                <TextBlock Text="{DynamicResource S.kee50ff}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="{DynamicResource S.k9de90b}" FontSize="12"
                           Foreground="#BDBDBD"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 結果清單：動態欄位由 code-behind 建立 -->
            <Border Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer x:Name="DiffScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DiffContainer"/>
                </ScrollViewer>
            </Border>

            <!-- 忙碌遮罩 -->
            <Border Background="#CCFFFFFF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="240" Height="4"
                                 Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ Row 3：狀態列 ══ -->
        <Border Grid.Row="3" Background="White"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- 圖例 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#E8F5E9" CornerRadius="3" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="{DynamicResource S.k66ab5e}" FontSize="11" Foreground="#2E7D32"/>
                        </Border>
                        <Border Background="#FEECEC" CornerRadius="3" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="{DynamicResource S.k0c06d4}" FontSize="11" Foreground="#C62828"/>
                        </Border>
                        <Border Background="#FFF8E1" CornerRadius="3" Padding="8,3">
                            <TextBlock Text="{DynamicResource S.k8347a9}" FontSize="11" Foreground="#E65100"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
