<Window x:Class="MySQLManager.Views.SchemaCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.k87eba2}" Height="620" Width="1000"
        MinWidth="760" MinHeight="480"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 選擇列 -->
            <RowDefinition Height="Auto"/>   <!-- 統計列 -->
            <RowDefinition Height="*"/>      <!-- 主體 -->
            <RowDefinition Height="Auto"/>   <!-- 狀態 -->
        </Grid.RowDefinitions>

        <!-- ─ 選擇資料庫 ─ -->
        <Border Grid.Row="0" Background="#F0F2F5" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource S.k2cd3b1}" Foreground="#78909C" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Databases}"
                              SelectedItem="{Binding LeftDatabase}"
                              Background="#E8ECF0" Foreground="White"
                              BorderBrush="#9E9E9E" Padding="8,5"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="VS" Foreground="#9E9E9E"
                           FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,0"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource S.ke5b9bc}" Foreground="#78909C" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Databases}"
                              SelectedItem="{Binding RightDatabase}"
                              Background="#E8ECF0" Foreground="White"
                              BorderBrush="#9E9E9E" Padding="8,5"/>
                </StackPanel>

                <Button Grid.Column="3" Content="{DynamicResource S.kee9297}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="16,18,0,0"
                        Command="{Binding CompareCommand}"/>
            </Grid>
        </Border>

        <!-- ─ 統計 ─ -->
        <Border Grid.Row="1" Background="#EEF4FF" Padding="12,6"
                Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <Border Background="#E6F4EA" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                    <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="12">
                        <Run Text="{DynamicResource S.kd1dbe9}"/>
                        <Run Text="{Binding AddedCount}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <Border Background="#FEECEC" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                    <TextBlock Foreground="{StaticResource ErrorBrush}" FontSize="12">
                        <Run Text="{DynamicResource S.k21adcc}"/>
                        <Run Text="{Binding RemovedCount}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <Border Background="#FFF8E1" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                    <TextBlock Foreground="#E65100" FontSize="12">
                        <Run Text="{DynamicResource S.k549775}"/>
                        <Run Text="{Binding ModifiedCount}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <Border Background="#EEF4FF" CornerRadius="4" Padding="10,4">
                    <TextBlock Foreground="#9E9E9E" FontSize="12">
                        <Run Text="{DynamicResource S.k99b5a7}"/>
                        <Run Text="{Binding SameCount}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <Button Content="{DynamicResource S.ALTERSQL242e95}" Margin="16,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#9E9E9E"
                        Command="{Binding CopyAlterSqlCommand}"/>
            </StackPanel>
        </Border>

        <!-- ─ 主體：左側資料表清單 + 右側差異詳情 ─ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 資料表清單 -->
            <Border Grid.Column="0" Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F0F2F5" Padding="10,7">
                        <TextBlock Text="{DynamicResource S.k1e5464}" Foreground="#78909C" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Pairs}"
                             SelectedItem="{Binding SelectedPair, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TableName}"
                                               Foreground="White" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" CornerRadius="3" Padding="5,1" Margin="4,0,0,0">
                                        <Border.Background>
                                            <Binding Path="KindColor" Converter="{StaticResource StringToBrush}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding KindLabel}"
                                                   Foreground="White" FontSize="10"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"    Value="10,5"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F2F5"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected"   Value="True">
                                        <Setter Property="Background" Value="#D2E3FC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="#F0F2F5" HorizontalAlignment="Stretch"/>

            <!-- 差異詳情 -->
            <Border Grid.Column="2" Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 欄名標題列 -->
                    <Grid Grid.Row="0" Background="#F0F2F5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource S.k8e607d}" Foreground="#78909C" FontSize="11" FontWeight="SemiBold" Padding="10,7"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource S.k84c1fa}" Foreground="#78909C" FontSize="11" FontWeight="SemiBold" Padding="4,7"/>
                        <TextBlock Grid.Column="2" Text="{DynamicResource S.kd61a30}"  Foreground="#78909C" FontSize="11" FontWeight="SemiBold" Padding="4,7"/>
                        <TextBlock Grid.Column="3" Text="{Binding LeftDatabase, StringFormat='左側 ({0})'}"  Foreground="#78909C" FontSize="11" FontWeight="SemiBold" Padding="4,7"/>
                        <TextBlock Grid.Column="4" Text="{Binding RightDatabase, StringFormat='右側 ({0})'}" Foreground="#78909C" FontSize="11" FontWeight="SemiBold" Padding="4,7"/>
                    </Grid>

                    <!-- 差異列表 -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding SelectedPairAllDiffs}"
                              Background="Transparent" BorderThickness="0"
                              FontFamily="Consolas" FontSize="11">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="5,2">
                                                <Border.Background>
                                                    <Binding Path="KindColor">
                                                        
                                                    </Binding>
                                                </Border.Background>
                                                <TextBlock Text="{Binding KindLabel}" Foreground="White" FontSize="10"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{DynamicResource S.k84c1fa}" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ObjectType}" Foreground="#78909C"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{DynamicResource S.kd61a30}" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="#1976D2" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{DynamicResource S.k01273d}" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LeftValue}" Foreground="#37474F" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{DynamicResource S.k6fca1e}" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RightValue}" Foreground="#37474F" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding"    Value="0,3"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F2F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ─ 狀態列 ─ -->
        <Border Grid.Row="3" Background="#F0F2F5" Padding="12,6">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="3"
                                 Foreground="#1976D2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ProgressText}" Foreground="#78909C" FontSize="11"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="#9E9E9E" FontSize="11"
                           Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
