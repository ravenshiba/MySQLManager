<Window x:Class="MySQLManager.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.k2ec6bc}" Height="220" Width="380"
        MinWidth="340" MinHeight="200"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
    </Window.Resources>
    <StackPanel Margin="24">
        <TextBlock Text="{DynamicResource S.k17ce77}" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
        <PasswordBox x:Name="Pwd1" Height="32" Padding="8,0" FontSize="12" Margin="0,0,0,12"/>
        <TextBlock Text="{DynamicResource S.ka4460c}" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
        <PasswordBox x:Name="Pwd2" Height="32" Padding="8,0" FontSize="12" Margin="0,0,0,24"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource S.k625fb2}" Width="80" Height="32" Click="Cancel_Click"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.k30749e}" Width="80" Height="32" Click="Ok_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="{StaticResource AccentBrush}"/>
        </StackPanel>
    </StackPanel>
</Window>
