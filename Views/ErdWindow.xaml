<Window x:Class="MySQLManager.Views.ErdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.ERDf61095}" Height="680" Width="1000"
        MinHeight="520" MinWidth="760"
        Background="#FFFFFF"
        FontFamily="Segoe UI, Microsoft JhengHei, sans-serif"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <Border Grid.Row="0" Background="#EEF4FF" Padding="10,6"
                BorderBrush="#2C3E50" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="{DynamicResource S.ERDf61095}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#5DADE2" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button x:Name="BtnZoomIn"  Content="＋" Width="30" Height="28"
                            Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"
                            Margin="0,0,4,0" FontSize="16" Cursor="Hand"
                            Click="BtnZoomIn_Click"/>
                    <Button x:Name="BtnZoomOut" Content="－" Width="30" Height="28"
                            Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"
                            Margin="0,0,4,0" FontSize="16" Cursor="Hand"
                            Click="BtnZoomOut_Click"/>
                    <Button Content="{DynamicResource S.k0b2fdd}" Height="28"
                            Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"
                            Padding="10,0" Margin="0,0,4,0" Cursor="Hand"
                            Click="BtnFit_Click"/>
                    <Button Content="{DynamicResource S.kb947a3}" Height="28"
                            Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"
                            Padding="10,0" Cursor="Hand" Click="BtnReset_Click"/>
                    <Separator Width="1" Background="#3C4A5A" Margin="8,4"/>
                    <Button Content="{DynamicResource S.kdd2b14}" Height="28"
                            Background="#27AE60" Foreground="White" BorderThickness="0"
                            Padding="10,0" Margin="0,0,4,0" Cursor="Hand"
                            Click="BtnAutoLayout_Click" ToolTip="{DynamicResource S.Forcedir15b8f7}"/>
                    <Button Content="{DynamicResource S.PNG0de2a0}" Height="28"
                            Background="#8E44AD" Foreground="White" BorderThickness="0"
                            Padding="10,0" Cursor="Hand"
                            Click="BtnExportPng_Click" ToolTip="{DynamicResource S.PNG0fb225}"/>
                    <TextBlock x:Name="ZoomLabel" Text="100%"
                               Foreground="#7F8C8D" FontSize="12"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="StatsText" HorizontalAlignment="Right"
                           Foreground="#7F8C8D" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 主畫布 -->
        <Border Grid.Row="1" Background="#FFFFFF" ClipToBounds="True"
                x:Name="CanvasBorder"
                MouseWheel="Canvas_MouseWheel"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                MouseMove="Canvas_MouseMove">
            <Grid>
                <!-- 載入中 -->
                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="240" Height="4"
                                 Foreground="#5DADE2"/>
                    <TextBlock Text="{DynamicResource S.k55312e}" Foreground="#7F8C8D"
                               HorizontalAlignment="Center" Margin="0,12,0,0" FontSize="14"/>
                </StackPanel>

                <!-- ERD 縮放/平移容器 -->
                <Canvas x:Name="RootCanvas" Visibility="Collapsed">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ScaleT"/>
                            <TranslateTransform x:Name="TranslateT"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>
                    <Canvas x:Name="RelationCanvas"/>  <!-- 關聯線層 -->
                    <Canvas x:Name="TableCanvas"/>     <!-- 資料表層 -->
                </Canvas>
            </Grid>
        </Border>

        <!-- 狀態列 -->
        <Border Grid.Row="2" Background="#EEF4FF" Padding="10,5"
                BorderBrush="#2C3E50" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText"
                       Text="{DynamicResource S.k0f545c}"
                       Foreground="#7F8C8D" FontSize="11"/>
        </Border>
    </Grid>
</Window>
