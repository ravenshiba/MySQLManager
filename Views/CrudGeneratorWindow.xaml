<Window x:Class="MySQLManager.Views.CrudGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MySQLManager.Helpers"
        Title="{DynamicResource S.CRUD56b3aa}" Width="880"
        MinWidth="680" MinHeight="480" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5"
        FontFamily="Segoe UI, Microsoft JhengHei">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:InverseBoolConverter             x:Key="InverseBool"/>
            <helpers:NullToVisibilityConverter        x:Key="NullToVisibility"/>
            <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <helpers:StringToBrushConverter           x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左側：選擇設定 -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="12">
                <TextBlock Text="{DynamicResource S.k29fc03}" FontSize="13" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,16"/>

                <TextBlock Text="{DynamicResource S.k2801a2}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <ComboBox x:Name="DatabaseCombo" Margin="0,0,0,12"
                          SelectionChanged="DatabaseCombo_Changed"/>

                <TextBlock Text="{DynamicResource S.k7b5e7c}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <ComboBox x:Name="TableCombo" Margin="0,0,0,12"
                          SelectionChanged="TableCombo_Changed"/>

                <TextBlock Text="{DynamicResource S.k84f813}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <RadioButton x:Name="RbCSharp"    Content="C# (Dapper)"           Margin="0,0,0,6" IsChecked="True" Checked="Language_Changed"/>
                <RadioButton x:Name="RbPython"    Content="Python (mysql-connector)" Margin="0,0,0,6" Checked="Language_Changed"/>
                <RadioButton x:Name="RbPhp"       Content="PHP (PDO)"             Margin="0,0,0,6" Checked="Language_Changed"/>
                <RadioButton x:Name="RbTypeScript" Content="TypeScript (mysql2)"   Margin="0,0,0,16" Checked="Language_Changed"/>

                <Button Content="{DynamicResource S.ke8e770}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="0,10" Click="Generate_Click"/>

                <Button Content="{DynamicResource S.k91ee86}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,8,0,0" Padding="0,8"
                        Click="Copy_Click"/>

                <Button Content="{DynamicResource S.kc63c95}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,8,0,0" Padding="0,8"
                        Click="Save_Click"/>

                <!-- 欄位清單 -->
                <TextBlock Text="{DynamicResource S.k20ab43}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,20,0,6"/>
                <Border BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4" MaxHeight="180">
                    <ListBox x:Name="ColumnList" BorderThickness="0"
                             Background="Transparent" FontFamily="Consolas"
                             FontSize="11">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔑 " FontSize="10"
                                               Visibility="{Binding Key,
                                               Converter={StaticResource NullOrEmptyToVisibility}}"/>
                                    <TextBlock Text="{Binding Field}"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text=" " />
                                    <TextBlock Text="{Binding Type}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </StackPanel>
        </Border>

        <!-- 右側：生成的程式碼 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                    Padding="12,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="HeaderText"
                           Text="{DynamicResource S.kbd107f}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"/>
            </Border>

            <Border Grid.Row="1" Background="#1E1E1E">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="CodeOutput"
                             FontFamily="Consolas, Courier New" FontSize="12"
                             Background="Transparent"
                             Foreground="#D4D4D4"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             Padding="16"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
